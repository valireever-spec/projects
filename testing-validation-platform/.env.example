# Copy this file to .env and customize for your environment
# .env is gitignored; never commit actual secrets

# Tracker Configuration
TRACKER_URL=http://127.0.0.1:8001
PROJECT_NAME=investing-platform
# PROJECT_ID will be auto-detected; only set if needed
# PROJECT_ID=1

# Sync Configuration
# How often to run sync cycle (seconds)
SYNC_INTERVAL=300

# How many times to retry on failure
SYNC_RETRIES=3

# Initial retry delay (exponential backoff: 2s, 4s, 8s)
SYNC_RETRY_DELAY=2

# API Configuration
API_HOST=127.0.0.1
API_PORT=8004

# API request timeout (seconds)
API_TIMEOUT=30

# Dashboard Configuration
# How often dashboard auto-refreshes (seconds)
DASHBOARD_AUTO_REFRESH=30

# Logging Configuration
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json (structured) or text (plain)
LOG_FORMAT=json
