@rule("Prize StartStop", description="Item Prize_Power ONOFF", tags=["ONOFF", "Prize"])
@when("Item vTimeOfDay changed")
def prize_startstop(event):
    day = "DAY"
    evening = "EVENING"
    bed = "BED"
    morning = "MORNING"
    night = "NIGHT"
    afternoon = "AFTERNOON"
    if items["vTimeOfDay"] == StringType(bed):
        #events.sendCommand("Priza5_Power", "OFF")
        ctrl_dev("Priza5_Power", "OFF", items, events, command_type="sendCommand")  ###29.03.2024
        #events.sendCommand("Priza6_Power", "OFF")
        ctrl_dev("Priza6_Power", "OFF", items, events, command_type="sendCommand")  ###29.03.2024
#        events.sendCommand("Priza4_Power", "OFF") ###08.05.2022### A fost transformata Priza4 pentru laptop
#        if priza4Timeroff is not None: ###08.05.2022### A fost transformata Priza4 pentru laptop
#            priza4Timeroff.cancel() ###08.05.2022### A fost transformata Priza4 pentru laptop
        events.sendCommand("Striplight_Adina", "OFF")
        events.sendCommand("Striplight_Alex", "OFF")
    elif items["vTimeOfDay"] == StringType(day):
        if items["Sufragerie_Daytime"] == ON or items["Sufragerie_Illuminance_Switch"] == OFF:  # update 06.06.2022 #este lumina in camera:
            events.sendCommand("Priza5_Power", "OFF")
        if items["DormP_Daytime"] == ON or items["DormitorP_Illuminance_Switch"] == OFF: # update 06.06.2022 #este lumina in camera:
            #events.sendCommand("Priza6_Power", "OFF")
            events.sendCommand("Striplight_Alex", "OFF")
        if items["DormC_Daytime"] == ON or items["DormitorC_Illuminance_Switch"] == OFF: # update 06.06.2022 #este lumina in camera:
            events.sendCommand("Striplight_Adina", "OFF")
            #events.sendCommand("Striplight_Alex", "OFF")
    elif items["vTimeOfDay"] == StringType(evening):
        if items["DarkSufra"] == OFF:
            if items["HomePresence"] == ON:
                ctrl_dev("Priza5_Power", "ON", items, events, command_type="sendCommand")  ###29.03.2024
        if items["DarkDormP"] == OFF:
            if items["HomePresence"] == ON:
                #ctrl_dev("Priza6_Power", "ON", items, events, command_type="sendCommand")  ###29.03.2024
                events.sendCommand("Striplight_Alex", "ON")
    elif items["vTimeOfDay"] == StringType(night):
