# FIX: original rule was named "Logic Lightstrip when Sonoffmini1 turns off"
# but triggered on Sonoffmini1_Alive changed. A second rule below was also
# named "Logic Lightstrip when Sonoffmini1 turns off" but triggered on
# Sonoffmini2_Alive changed — second silently overwrote first in rule registry.
# Fixed: unique descriptive names for both.
@rule("Logic Lightstrip Sonoffmini1 Alive changed", description="Logic Lightstrip when Sonoffmini1 Alive changed", tags=["light", "Sonoffmini1", "Lightstrip DormC"])
@when("Item Sonoffmini1_Alive changed")
def logic_lightstrip_dormc_alive(event):
    day = "DAY"
    evening = "EVENING"
    evening_kids = "EVENING_KIDS"
    bed = "BED"
    bed_kids = "BED_KIDS"
    morning = "MORNING"
    afternoon = "AFTERNOON"
    spring = "Spring"
    summer = "Summer"
    autumn = "Autumn"
    winter = "Winter"
    if event.itemState == OFF:
        if items["DormC_Daytime"] == OFF or items["DormitorC_Illuminance_Switch"] == ON: # update 06.06.2022 #este intuneric in camera
            if items["altTimeOfDay"] == StringType(evening_kids) or items["vTimeOfDay"] == StringType(day) or items["vTimeOfDay"] == StringType(afternoon):
                if items["AstroSunData_Season_SeasonName"] != StringType(summer) and items["AstroSunData_Season_SeasonName"] != StringType(spring):
                    if items["HomePresence"] == ON:
                        events.sendCommand("Striplight_Adina", "ON")
            elif items["vTimeOfDay"] == StringType(morning):
                if items["AstroSunData_Season_SeasonName"] != StringType(summer) and items["AstroSunData_Season_SeasonName"] != StringType(spring):
                    if items["Schulfrei_Adina"] == OFF:
                        events.sendCommand("Striplight_Adina", "ON")
            elif items["vTimeOfDay"] == StringType(bed_kids):
                    events.sendCommand("Striplight_Adina", "OFF")

    if event.itemState == ON:
        if items["Sonoffmini1_Active"] == ON:   ###TEST 29.04.2023!###
            LogAction.logInfo(str(event.itemName), "este activ")
            events.sendCommand("Striplight_Adina", "OFF")

