@rule("Striplight_Adina", description="Striplight_Adina changed", tags=["light", "Striplight_Adina"])
@when("Item Striplight_Adina changed")
def striplight_adina(event):
    global timerLSAdina_on, timerLSAdina_off
    if event.itemState == OFF:
        timerLSAdina_off = createTimer(DateTime.now().plusMillis(500), lightstrip_adina_off)
    if event.itemState == ON:
        timerLSAdina_on = createTimer(DateTime.now().plusMillis(500), lightstrip_adina_on)

@rule("Striplight_Alex", description="Striplight_Alex changed", tags=["light", "Striplight_Alex"])
@when("Item Striplight_Alex changed")
def striplight_alex(event):
    global timerLSAlex_on, timerLSAlex_off
    if event.itemState == OFF:
        timerLSAlex_off = createTimer(DateTime.now().plusMillis(500), lightstrip_alex_off)
    if event.itemState == ON:
        timerLSAlex_on = createTimer(DateTime.now().plusMillis(500), lightstrip_alex_on)

def priza1_cancel_charge_end_timer():
    global DelayTimer1
    if DelayTimer1 is not None and not DelayTimer1.hasTerminated():
        if DelayTimer1 is not None:
            DelayTimer1.cancel()

def priza1_relay_max_current():
    """Upper current bound for Priza1 relay window — night/bed uses MaxCLevel_P1_Night when it is above MinCLevel_P1_1 (otherwise constants would form an empty band)."""
    is_night = items["vTimeOfDay"] == StringType(night) or items["vTimeOfDay"] == StringType(bed)
    # FIX-E: MaxCLevel_P1_Night = 0.095 A < MinCLevel_P1_1 = 0.300 A, so this
    # condition is always False — night branch is dead code. Update constants to
    # activate it; until then MaxCLevel_P1_Day is always returned.
    if is_night and safe_float(MaxCLevel_P1_Night) > safe_float(MinCLevel_P1_1):
        return MaxCLevel_P1_Night
    return MaxCLevel_P1_Day

def priza1_compute_teleperiod_sec(current):
    """Priza1_TelePeriod (seconds → device): high current = Shelly-matched fast; low = slow TelePeriod1_3."""
    if current > QuantityType(MinCLevel_P1_1):
        return TELE_PERIOD_P1_FAST_SEC
    return TelePeriod1_3

def timer1_charge_off():
    global _p1_timer_relay_open
    # FIX-F: set flag BEFORE opening relays so that the next priza1_Current event
    # (current→0 after relay open) skips BatteryFull detection — this is a timeout
    # relay-open, not a genuine full charge.
    _p1_timer_relay_open = True
    ctrl_dev("Priza1_Power", "ON", items, events, command_type="sendCommand")  ###29.03.2024
    ctrl_dev("Priza1_Relay1", "OFF", items, events, command_type="sendCommand")  ###29.03.2024
    ctrl_dev("Priza1_Relay2", "OFF", items, events, command_type="sendCommand")  ###29.03.2024
    if ir.getItem("Priza1_TelePeriod").state != TelePeriod_timeroff:
        events.postUpdate(ir.getItem("Priza1_TelePeriod"), (TelePeriod_timeroff))
        events.sendCommand(ir.getItem("Priza1_TelePeriod"), (TelePeriod_timeroff))
    priza1_cancel_charge_end_timer()

@rule("Priza1_Current", description="Item Priza1_Current changed", tags=["Current", "Priza1"])
@when("Item Priza1_Current changed")
def priza1_Current(event):
    global DelayTimer1, taperStartTime

    current = items["Priza1_Current"]
    p1_max = priza1_relay_max_current()
    p1_max_q = QuantityType(p1_max)
    in_taper_window = current > QuantityType(FULL_CURRENT) and current < QuantityType(TAPER_START_CURRENT)
    below_min_opens_relays = current <= QuantityType(MinCLevel_P1_1) and not in_taper_window

    # --- Original current-based relay logic ---
    if current <= p1_max_q and current > QuantityType(MinCLevel_P1_1):
        if items["Priza1_Relay1"] != ON:
            ctrl_dev("Priza1_Relay1", "ON", items, events)
        elif items["Priza1_Relay1"] == ON:
            if items["Priza1_Relay2"] != ON:
                ctrl_dev("Priza1_Relay2", "ON", items, events)
            if items["Priza1_Asc"] == OFF:
                ctrl_dev("Priza1_Power", "OFF", items, events)
        if DelayTimer1 is None or DelayTimer1.hasTerminated():
            DelayTimer1 = ScriptExecution.createTimer(DateTime.now().plusMinutes(timeoutMinutesP1), timer1_charge_off)
        if DelayTimer1 is not None and not DelayTimer1.hasTerminated():
            DelayTimer1.reschedule(DateTime.now().plusMinutes(timeoutMinutesP1))
    if current > p1_max_q or below_min_opens_relays:
        priza1_cancel_charge_end_timer()
        if items["Priza1_Relay2"] != OFF:
            ctrl_dev("Priza1_Relay2", "OFF", items, events)
        elif items["Priza1_Relay2"] == OFF:
            if items["Priza1_Relay1"] != OFF:
                ctrl_dev("Priza1_Relay1", "OFF", items, events)

    # --- TelePeriod → device (see priza1_compute_teleperiod_sec) ---
    teleperiod_value = priza1_compute_teleperiod_sec(current)
    tele_item = ir.getItem("Priza1_TelePeriod")
    if safe_float(tele_item.state) != teleperiod_value:
        events.postUpdate(tele_item, teleperiod_value)
        events.sendCommand(tele_item, teleperiod_value)

    # --- Taper detection (~80% charge) ---
    # FIX: taperStartTime now stores a DateTime object instead of time.time() float.
    # FIX2: taper block now also turns off Power and sets BatteryFull — consistent
    # with full-charge block — no standby draw, ECO sequence won't re-trigger.
    if current < QuantityType(TAPER_START_CURRENT) and current > QuantityType(FULL_CURRENT):
        if taperStartTime is None:
            taperStartTime = DateTime.now()
            LogAction.logInfo("E-Bike", "Tapering started (current {})".format(str(current)))
        else:
            elapsed_seconds = (DateTime.now().getMillis() - taperStartTime.getMillis()) / 1000.0
            if elapsed_seconds > TAPER_STABLE_DURATION:
                LogAction.logInfo("E-Bike", "Battery likely reached 80%. Stopping charge.")
                priza1_cancel_charge_end_timer()
                ctrl_dev("Priza1_Relay1", "OFF", items, events)
                ctrl_dev("Priza1_Relay2", "OFF", items, events)
                taperStartTime = None
                if not is_state(items["Priza1_BatteryFull"], OnOffType.ON):
                    events.sendCommand("Priza1_BatteryFull", "ON")
                    LogAction.logInfo("E-Bike", "Priza1_BatteryFull set ON at 80% taper")
                ctrl_dev("Priza1_Power", "OFF", items, events)
    else:
        taperStartTime = None

    # --- Full-charge detection ---
    # NEW: set Priza1_BatteryFull ON so 080_Power skips Priza1 in ECO ON-sequence.
    # Flag is reset by 019_Charge_curve when Priza1_Power turns ON (new charge cycle).
    # FIX1: guard against current=0 re-triggering this block after Power OFF —
    # when Power is already OFF there is nothing to do, return immediately.
    # FIX-F: guard against current=0 caused by timer1_charge_off opening relays —
    # that is a timeout stop, not a genuine full charge; clear flag and return.
    if current <= QuantityType(FULL_CURRENT):
        global _p1_timer_relay_open
        # FIX-F: guard against current=0 caused by timeout relay-open (not a genuine full charge)
        if _p1_timer_relay_open:
            _p1_timer_relay_open = False
            LogAction.logInfo("E-Bike", "current=0 after timeout relay-open — BatteryFull NOT set")
            return
        # BUG FIX (2026-06-20): Never return early before setting BatteryFull. Race condition:
        # if Priza1_Power was already OFF, we would return without activating the flag.
        # Solution: always detect and flag full charge, regardless of Power state.
        LogAction.logInfo("E-Bike", "Charging complete (trickle current).")
        priza1_cancel_charge_end_timer()
        ctrl_dev("Priza1_Relay1", "OFF", items, events)
        ctrl_dev("Priza1_Relay2", "OFF", items, events)
        taperStartTime = None
        # Always set BatteryFull when full charge is detected, even if Power is already OFF
        if not is_state(items["Priza1_BatteryFull"], OnOffType.ON):
            events.sendCommand("Priza1_BatteryFull", "ON")
            LogAction.logInfo("E-Bike", "Priza1_BatteryFull set ON — ECO sequence will skip Priza1")
        # Turn socket off immediately — no standby draw, no accidental re-trigger
        if is_state(items["Priza1_Power"], OnOffType.ON):
            ctrl_dev("Priza1_Power", "OFF", items, events)

@rule("Priza1 control logic")
@when("Item Priza1_Power_man changed")
@when("Item Priza1_Power_auto changed")
def priza1_control(event):
    man  = items["Priza1_Power_man"]
    auto = items["Priza1_Power_auto"]
    pz1  = items["Priza1_Power"]

    # Manual override ON → clear BatteryFull latch then force ON
    if is_state(man, OnOffType.ON):
        if not is_state(items["Priza1_BatteryFull"], OnOffType.OFF):
            events.sendCommand("Priza1_BatteryFull", "OFF")
            LogAction.logInfo("Priza1", "Priza1_BatteryFull cleared — manual override")
        if not is_state(pz1, OnOffType.ON):
            events.sendCommand("Priza1_Power", "ON")
        return

    # Manual override OFF → auto decides; BatteryFull blocks auto ON
    if is_state(auto, OnOffType.ON):
        if is_state(items["Priza1_BatteryFull"], OnOffType.ON):
            LogAction.logInfo("Priza1", "Priza1_Power auto ON blocked — BatteryFull is ON")
            events.postUpdate("Priza1_Power_auto", "OFF")  # FIX-G: removed redundant 'if auto != OFF' (always True here)
            return
        if not is_state(pz1, OnOffType.ON):
            events.sendCommand("Priza1_Power", "ON")
    else:
        if not is_state(pz1, OnOffType.OFF):
            events.sendCommand("Priza1_Power", "OFF")

@rule("Priza1 Power logic")
@when("Item Priza1_Power changed")
def priza1_power_event(event):
    man  = items["Priza1_Power_man"]
    auto = items["Priza1_Power_auto"]
    pz1 = items["Priza1_Power"]
    
    if pz1 == OFF:
        if man != OFF:
            events.postUpdate("Priza1_Power_man", "OFF")
        if auto != OFF:
            events.postUpdate("Priza1_Power_auto", "OFF")

def timer2_charge_off():
    ctrl_dev("Priza2_Power", "ON", items, events, command_type="sendCommand")
    ctrl_dev("Priza2_Relay1", "OFF", items, events, command_type="sendCommand")
    ctrl_dev("Priza2_Relay2", "OFF", items, events, command_type="sendCommand")
    if ir.getItem("Priza2_TelePeriod").state != TelePeriod_timeroff:
        events.postUpdate(ir.getItem("Priza2_TelePeriod"), (TelePeriod_timeroff))
        events.sendCommand(ir.getItem("Priza2_TelePeriod"), (TelePeriod_timeroff))
    if DelayTimer2 is not None:
        DelayTimer2.cancel()

