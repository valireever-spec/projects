#Reguli de aprindere a becurilor si LED-Strip-urilor#

@rule("Logic Lightstrip when Sonoffmini2 turns on or off", description="Logic Lightstrip when Sonoffmini2 turns on or off", tags=["light", "Sonoffmini2", "Lightstrip DormP"])
@when("Item Sonoffmini2_Alive changed")
def logic_lightstrip_dormp_off(event):
    day = "DAY"
    evening = "EVENING"
    bed = "BED"
    morning = "MORNING"
    afternoon = "AFTERNOON"
    spring = "Spring"
    summer = "Summer"
    autumn = "Autumn"
    winter = "Winter"
    # FIX: time.sleep(10) blocked the rule engine thread.
    # Replaced with a timer so the rule returns immediately.
    def _delayed_dormp(event=event):
        if event.itemState == OFF:
            if items["DormP_Daytime"] == OFF or items["DormitorP_Illuminance_Switch"] == ON: # update 06.06.2022 #este intuneric in camera
                if items["vTimeOfDay"] == StringType(evening) or items["vTimeOfDay"] == StringType(day) or items["vTimeOfDay"] == StringType(afternoon):
                    if items["DarkDormP"] == OFF:
                        if items["HomePresence"] == ON:
                            events.sendCommand("Striplight_Alex", "ON")
                elif items["vTimeOfDay"] == StringType(morning):
                    events.sendCommand("Striplight_Alex", "ON")
        if event.itemState == ON:
            if items["Sonoffmini2_Active"] == ON:
                LogAction.logInfo(str(event.itemName), "este activ")
                events.sendCommand("Striplight_Alex", "OFF")
    ScriptExecution.createTimer(DateTime.now().plusSeconds(10), _delayed_dormp)

