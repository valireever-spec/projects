###08.05.2022### A fost transformata Priza4 pentru laptop

def priza4_cancel_charge_end_timer():
    global DelayTimer4
    if DelayTimer4 is not None and not DelayTimer4.hasTerminated():
        if DelayTimer4 is not None:
            DelayTimer4.cancel()

def priza4_cancel_leave_debounce():
    global priza4LeaveDebounceTimer
    if priza4LeaveDebounceTimer is not None and not priza4LeaveDebounceTimer.hasTerminated():
        if priza4LeaveDebounceTimer is not None:
            priza4LeaveDebounceTimer.cancel()
    priza4LeaveDebounceTimer = None

def priza4_leave_trickle_current_band():
    """No longer in trickle window — heavy charge, unplug, or relays opened. Drop full latch."""
    priza4_cancel_leave_debounce()
    priza4_cancel_charge_end_timer()
    ctrl_dev("Priza4_BatteryFull", "OFF", items, events, command_type="sendCommand")

def priza4_leave_trickle_debounced_fire():
    global priza4LeaveDebounceTimer
    priza4LeaveDebounceTimer = None
    priza4_leave_trickle_current_band()

def priza4_schedule_leave_trickle():
    """Avoid clearing Priza4_BatteryFull on noisy current spikes out of the trickle band."""
    global priza4LeaveDebounceTimer
    priza4_cancel_leave_debounce()
    priza4LeaveDebounceTimer = ScriptExecution.createTimer(
        DateTime.now().plusSeconds(PRIZA4_LEAVE_DEBOUNCE_SEC),
        priza4_leave_trickle_debounced_fire
    )

def timer4_charge_off():
    priza4_cancel_leave_debounce()
    ctrl_dev("Priza4_Power", "ON", items, events, command_type="sendCommand")
    ctrl_dev("Priza4_BatteryFull", "OFF", items, events, command_type="sendCommand")
    ctrl_dev("Priza4_Relay1", "OFF", items, events, command_type="sendCommand")
    ctrl_dev("Priza4_Relay2", "OFF", items, events, command_type="sendCommand")
    if ir.getItem("Priza4_TelePeriod").state != TelePeriod_timeroff:
        events.postUpdate(ir.getItem("Priza4_TelePeriod"), (TelePeriod_timeroff))
        events.sendCommand(ir.getItem("Priza4_TelePeriod"), (TelePeriod_timeroff))
    priza4_cancel_charge_end_timer()

@rule("Priza4_Power cancel end timer", description="When Priza4 outlet turns ON, cancel full-charge delay timer", tags=["Priza4", "Power"])
@when("Item Priza4_Power changed")
def priza4_power_cancel_end_timer(event):
    if event.itemState == ON:
        priza4_cancel_leave_debounce()
        priza4_cancel_charge_end_timer()

@rule("Priza4_Current", description="Item Priza4_Current changed", tags=["Current", "Priza4"])
@when("Item Priza4_Current changed")
def Priza4_Current(event):
    global DelayTimer4

    if items["AstroSunData_Season_SeasonName"] == StringType(SPRING) or items["AstroSunData_Season_SeasonName"] == StringType(SUMMER) or items["AstroSunData_Season_SeasonName"] == StringType(AUTUMN):
        if items["Eco_Power_Switch"] == ON:
            handle_eco_P4()
        else:
            if items["vTimeOfDay"] == StringType(night) or items["vTimeOfDay"] == StringType(bed):
                handle_noneco_P4_night()
            else:
                handle_noneco_P4_day()
    else: #WINTER
        if items["vTimeOfDay"] == StringType(night) or items["vTimeOfDay"] == StringType(bed):
            handle_noneco_P4_night()
        else:
            handle_eco_P4()
    update_teleperiod_based_on_current_P4()

def handle_eco_P4(): #Day & Summer
    global DelayTimer4
    if items["vTimeOfDay"] == StringType(morning) or items["vTimeOfDay"] == StringType(day) or items["vTimeOfDay"] == StringType(afternoon) or items["vTimeOfDay"] == StringType(evening):
        if items["Priza4_Current"] <= QuantityType((MaxCLevel_P4_Day)) and items["Priza4_Current"] > QuantityType((MinCLevel_P4_1)):
            priza4_cancel_leave_debounce()
            if items["Priza4_Relay1"] != ON:
                events.sendCommand("Priza4_Relay1", "ON")
            elif items["Priza4_Relay1"] == ON:
                if items["Priza4_Relay2"] != ON:
                    events.sendCommand("Priza4_Relay2", "ON")
                if items["Priza4_Asc"] == OFF:
                    events.sendCommand("Priza4_Power", "OFF")
                    ctrl_dev("Priza4_BatteryFull", "ON", items, events, command_type="sendCommand")

            events.postUpdate(ir.getItem("Priza4_TelePeriod"), (TelePeriod_timeroff))
            events.sendCommand(ir.getItem("Priza4_TelePeriod"), (TelePeriod_timeroff))
            if DelayTimer4 is None or DelayTimer4.hasTerminated():
                DelayTimer4 = ScriptExecution.createTimer(DateTime.now().plusMinutes(timeoutMinutes), timer4_charge_off)
            if DelayTimer4 is not None and not DelayTimer4.hasTerminated():
                DelayTimer4.reschedule(DateTime.now().plusMinutes(timeoutMinutes))
        if items["Priza4_Current"] > QuantityType((MaxCLevel_P4_Day)) or items["Priza4_Current"] <= QuantityType((MinCLevel_P4_1)):
            priza4_schedule_leave_trickle()
            if items["Priza4_Relay2"] == ON:
                events.sendCommand("Priza4_Relay2", "OFF")
            elif items["Priza4_Relay2"] == OFF:
                if items["Priza4_Relay1"] != OFF:
                    events.sendCommand("Priza4_Relay1", "OFF")

def handle_noneco_P4_day():
    global DelayTimer4
    if items["Priza4_Current"] <= QuantityType((MaxCLevel_P4_Day)) and items["Priza4_Current"] > QuantityType((MinCLevel_P4_1)):
        priza4_cancel_leave_debounce()
        ctrl_dev("Priza4_Relay1", "ON", items, events, command_type="sendCommand")
        if items["Priza4_Relay1"] == ON:
            ctrl_dev("Priza4_Relay2", "ON", items, events, command_type="sendCommand")
            if items["Priza4_Asc"] == OFF:
                ctrl_dev("Priza4_Power", "OFF", items, events, command_type="sendCommand")
                ctrl_dev("Priza4_BatteryFull", "ON", items, events, command_type="sendCommand")

        events.postUpdate(ir.getItem("Priza4_TelePeriod"), (TelePeriod_timeroff))
        events.sendCommand(ir.getItem("Priza4_TelePeriod"), (TelePeriod_timeroff))
        if DelayTimer4 is None or DelayTimer4.hasTerminated():
            DelayTimer4 = ScriptExecution.createTimer(DateTime.now().plusMinutes(timeoutMinutesP4), timer4_charge_off)
        if DelayTimer4 is not None and not DelayTimer4.hasTerminated():
            DelayTimer4.reschedule(DateTime.now().plusMinutes(timeoutMinutesP4))
    if items["Priza4_Current"] > QuantityType((MaxCLevel_P4_Day)) or items["Priza4_Current"] <= QuantityType((MinCLevel_P4_1)):
        priza4_schedule_leave_trickle()
        ctrl_dev("Priza4_Relay2", "OFF", items, events, command_type="sendCommand")
        if items["Priza4_Relay2"] == OFF:
            ctrl_dev("Priza4_Relay1", "OFF", items, events, command_type="sendCommand")

def handle_noneco_P4_night():
    global DelayTimer4
    if items["Priza4_Current"] <= QuantityType((MaxCLevel_P4_Night)) and items["Priza4_Current"] > QuantityType((MinCLevel_P4_1)):
        priza4_cancel_leave_debounce()
        ctrl_dev("Priza4_Relay1", "ON", items, events, command_type="sendCommand")
