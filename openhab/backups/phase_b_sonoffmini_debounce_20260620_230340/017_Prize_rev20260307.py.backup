def lightstrip_adina_on():
    ctrl_dev("Led_Contr_Adina_Power", "ON", items, events, command_type="sendCommand")  ###29.03.2024
    events.sendCommand("Led_Contr_Adina_Color", "120,2,10")
    if timerLSAdina_on is not None and not timerLSAdina_on.hasTerminated():
        if timerLSAdina_on is not None:
            timerLSAdina_on.cancel()

def lightstrip_adina_off():
    ctrl_dev("Led_Contr_Adina_Power", "OFF", items, events, command_type="sendCommand")  ###29.03.2024
    if timerLSAdina_off is not None and not timerLSAdina_off.hasTerminated():
        if timerLSAdina_off is not None:
            timerLSAdina_off.cancel()

def lightstrip_alex_on():
    ctrl_dev("Led_Contr_Alex_Power", "ON", items, events, command_type="sendCommand")  ###29.03.2024
    events.sendCommand("Led_Contr_Alex_Color", "120,2,10")
    if timerLSAlex_on is not None and not timerLSAlex_on.hasTerminated():
