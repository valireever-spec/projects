###Adaugat la 29.08.2021###
@rule("Natural light off", description="Item DaylightPhilips_Dark received update on", tags=["Lumina naturala"])
@when("Item DaylightPhilips_Dark received update")
def natural_light_off(event):
    if event.itemState == ON:
        events.sendCommand("Sufragerie_Daytime", "OFF")
        events.sendCommand("Bucatarie_Daytime", "OFF")
        events.sendCommand("DormP_Daytime", "OFF")
        events.sendCommand("DormC_Daytime", "OFF")
        natural_light_off = executeCommandLine("/etc/openhab2/scripts/daylight.sh night", 10000)  #Update 21.05.2024
        LogAction.logInfo("Natural light off", "Nu este destula lumina naturala afara")
@rule("Natural light on", description="Item DaylightPhilips_Dark received update off", tags=["Lumina naturala"])
@when("Item DaylightPhilips_Dark received update")
def natural_light_on(event):
    spring = "Spring"
    summer = "Summer"
    autumn = "Autumn"
    winter = "Winter"
    if event.itemState == OFF:
        natural_light_off = executeCommandLine("/etc/openhab2/scripts/daylight.sh day", 10000) #Update 21.05.2024
        if items["AstroSunData_Season_SeasonName"] == StringType(summer): #or items["AstroSunData_Season_SeasonName"] == StringType(spring):
            events.sendCommand("Sufragerie_Daytime", "ON")
            events.sendCommand("Bucatarie_Daytime", "ON")
            events.sendCommand("DormP_Daytime", "ON")
            events.sendCommand("DormC_Daytime", "ON")
            natural_light_on.log.info("Este destula lumina naturala afara")
