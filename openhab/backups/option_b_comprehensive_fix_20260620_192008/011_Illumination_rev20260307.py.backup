@rule("Sufra_Light_Illuminance changed", description="Sufra_Light_Illuminance changed", tags=["Sufra_Light"])
@when("Item Sufra1_Light_Illuminance changed")
@when("Item Sufra2_Light_Illuminance changed")
def sufra_illum_level(event):
    global valIllumSufra 
    valIllumSufra1 = None
    valIllumSufra2 = None
    levelLightSufra = 0.0  # Initialize levelLightSufra
    morning = "MORNING"
    day = "DAY"
    afternoon = "AFTERNOON"
    evening = "EVENING"
    night = "NIGHT"
    bed = "BED"
    if items["vTimeOfDay"] == StringType(day) or items["vTimeOfDay"] == StringType(afternoon) or items["vTimeOfDay"] == StringType(evening): #or items["vTimeOfDay"] == StringType(morning):
        if items["OffFlagLamp"] == OFF:
            illuminance_values = {
                QuantityType(u"18.0 lx"): 18, QuantityType(u"17.0 lx"): 17, QuantityType(u"16.0 lx"): 16,
                QuantityType(u"15.0 lx"): 15, QuantityType(u"14.0 lx"): 14, QuantityType(u"13.0 lx"): 13,
                QuantityType(u"12.0 lx"): 12, QuantityType(u"11.0 lx"): 11, QuantityType(u"10.0 lx"): 10,
                QuantityType(u"9.0 lx"): 9, QuantityType(u"8.0 lx"): 8, QuantityType(u"7.0 lx"): 7,
                QuantityType(u"6.0 lx"): 6, QuantityType(u"5.0 lx"): 5, QuantityType(u"4.0 lx"): 4,
                QuantityType(u"3.0 lx"): 3, QuantityType(u"2.0 lx"): 2, QuantityType(u"1.0 lx"): 1,
                QuantityType(u"0.0 lx"): 0
            }
            valIllumSufra1 = illuminance_values.get(items["Sufra1_Light_Illuminance"], None)
            valIllumSufra2 = illuminance_values.get(items["Sufra2_Light_Illuminance"], None)
            if valIllumSufra1 is not None and valIllumSufra2 is not None:
                valIllumSufra = (valIllumSufra1 + valIllumSufra2) / 2
                # FIX-sleep: removed sleep(0.5) x2 — they were between pure arithmetic, no I/O needed
                levelLightSufra = valIllumSufra + ((18 - valIllumSufra) * 5.5)
                if items["OffFlagLamp"] == OFF:
                    if items["Sufra_Presence"] == ON:
                        if items["Logging"] == ON:
                            LogAction.logInfo("valIllumSufra", "changed to {} lx at {}", valIllumSufra, str(DateTime.now()))
                            LogAction.logInfo("levelLightSufra", "changed to {} at {}", levelLightSufra, str(DateTime.now()))
                        events.postUpdate("Bec_TechPro8_Dimmer", str(levelLightSufra))
                        events.postUpdate("Bec_TechPro9_Dimmer", str(levelLightSufra))
                        events.postUpdate("gBec_LampaSufra", "ON")
    elif items["vTimeOfDay"] == StringType(night) or items["vTimeOfDay"] == StringType(bed) or items["vTimeOfDay"] == StringType(morning):
        if items["Clock_alarm"] == OFF:
            events.postUpdate("Bec_TechPro8_Dimmer", str(0))
            events.postUpdate("Bec_TechPro9_Dimmer", str(0))
            events.postUpdate("gBec_LampaSufra", "OFF")
        elif items["Clock_alarm"] == ON:
            events.postUpdate("Bec_TechPro8_Dimmer", str(levelLightSufra))
            events.postUpdate("Bec_TechPro9_Dimmer", str(levelLightSufra))
            events.postUpdate("gBec_LampaSufra", "ON")