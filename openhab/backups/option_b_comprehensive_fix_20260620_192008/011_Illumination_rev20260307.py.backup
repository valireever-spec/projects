@rule("Decizie cand DormC1_Daytime e activ", description="Item DormC1_Daytime received command ON", tags=["Illumination", "DormitorC"])
@when("Item DormC1_Daytime received update")
def dormc1_daytime_switch(event):
    if event.itemState == ON:
        # FIX-sleep: replaced time.sleep(1) with createTimer
        def _dormc1_daytime_on():
            if items["Sonoffmini1_Alive"] == ON:
                if items["Sonoffmini1_Power"] != ON:
                    events.sendCommand("DormC_Daytime", "ON")
            #if ir.getItem("Sonoffmini1_Power").state != ON:
            if items["Sonoffmini1_Alive"] != ON:
                events.sendCommand("DormC_Daytime", "ON")
                if items["Logging"] == ON:
                    dormc1_daytime_switch.log.info("Daytime received command ON")
        ScriptExecution.createTimer(DateTime.now().plusSeconds(1), _dormc1_daytime_on)
    if event.itemState == OFF:
        if items["DormC2_Daytime"] == OFF:
            events.sendCommand("DormC_Daytime", "OFF")
            if items["Logging"] == ON:
                dormc1_daytime_switch.log.info("Daytime received command OFF")
@rule("Decizie cand DormC2_Daytime e activ", description="Item DormC2_Daytime received command ON", tags=["Illumination", "DormitorC"])
@when("Item DormC2_Daytime received update")
def dormc2_daytime_switch(event):
    if event.itemState == ON:
        # FIX-sleep: replaced time.sleep(1) with createTimer
        def _dormc2_daytime_on():
            if items["Sonoffmini1_Alive"] == ON:
                if items["Sonoffmini1_Power"] != ON:
                    events.sendCommand("DormC_Daytime", "ON")
            #if ir.getItem("Sonoffmini1_Power").state != ON:
            if items["Sonoffmini1_Alive"] != ON:
                events.sendCommand("DormC_Daytime", "ON")
                if items["Logging"] == ON:
                    dormc2_daytime_switch.log.info("Daytime received command ON")
        ScriptExecution.createTimer(DateTime.now().plusSeconds(1), _dormc2_daytime_on)
    if event.itemState == OFF:
        if items["DormC1_Daytime"] == OFF:
            events.sendCommand("DormC_Daytime", "OFF")
            if items["Logging"] == ON:
                dormc2_daytime_switch.log.info("Daytime received command OFF")
@rule("Daytime Sufragerie", description="Item Sufragerie_Daytime received command", tags=["Lumina naturala", "Sufragerie"])
@when("Item Sufragerie_Daytime received update")
def sufra_daylight(event):
