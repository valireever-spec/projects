@rule("DayLight_Philips", description="Item Bucatarie2_Illuminance changed", tags=["Illumination", "Bucatarie"])
@when("Item Bucatarie2_Presence received command")
def bucatarie2_illum(event):
    if event.itemCommand == ON:
#        if items["DaylightPhilips_DaylightValue"] < MinLightPhilips:
        if float(str(items["DaylightPhilips_DaylightValue"])) < MinLightPhilips and items["Philips_Daytime"] != ON:
            events.sendCommand("Philips_Daytime", "ON")
            if items["Logging"] == ON:
                bucatarie2_illum.log.info("Philips sensor measured enough light")
        elif float(str(items["DaylightPhilips_DaylightValue"]))>= MinLightPhilips and items["Philips_Daytime"] != OFF:
#        elif items["DaylightPhilips_DaylightValue"] > MinLightPhilips:
            events.sendCommand("Philips_Daytime", "OFF")
            if items["Logging"] == ON:
                bucatarie2_illum.log.info("Philips sensor measured enough light")
@rule("Decizie cand Sufragerie1_Daytime e activ", description="Item Sufragerie1_Daytime received command ON", tags=["Illumination", "Sufragerie"])
@when("Item Sufragerie1_Daytime received update")
def sufra1_daytime_switch(event):
    if event.itemState == ON:
        # FIX-sleep: replaced time.sleep(1) with createTimer to avoid blocking rule engine
        def _sufra1_daytime_on():
            if items["Sonoffmini3_Alive"] == ON:
                if items["Sonoffmini3_Power"] != ON and items["Sufragerie_Daytime"] != ON:
                    events.sendCommand("Sufragerie_Daytime", "ON")
            #if ir.getItem("Sonoffmini3_Power").state != ON:
            if items["Sonoffmini3_Alive"] != ON and items["Sufragerie_Daytime"] != ON:
                events.sendCommand("Sufragerie_Daytime", "ON")
                if items["Logging"] == ON:
                    sufra1_daytime_switch.log.info("Daytime received command ON")
        ScriptExecution.createTimer(DateTime.now().plusSeconds(1), _sufra1_daytime_on)
    if event.itemState == OFF:
        if items["Sufragerie2_Daytime"] == OFF and items["Sufragerie_Daytime"] != OFF:
            events.sendCommand("Sufragerie_Daytime", "OFF")
            if items["Logging"] == ON:
                sufra1_daytime_switch.log.info("Daytime received command OFF")
@rule("Decizie cand Sufragerie2_Daytime e activ", description="Item Sufragerie2_Daytime received command ON", tags=["Illumination", "Sufragerie"])
@when("Item Sufragerie2_Daytime received update")
def sufra2_daytime_switch(event):
    if event.itemState == ON:
        # FIX-sleep: replaced time.sleep(1) with createTimer
        def _sufra2_daytime_on():
            if items["Sonoffmini3_Alive"] == ON:
                if items["Sonoffmini3_Power"] != ON:
                    events.sendCommand("Sufragerie_Daytime", "ON")
            #if ir.getItem("Sonoffmini3_Power").state != ON:
            if items["Sonoffmini3_Alive"] != ON:
                events.sendCommand("Sufragerie_Daytime", "ON")
                if items["Logging"] == ON:
                    sufra2_daytime_switch.log.info("Daytime received command ON")
        ScriptExecution.createTimer(DateTime.now().plusSeconds(1), _sufra2_daytime_on)
    if event.itemState == OFF:
        if items["Sufragerie1_Daytime"] == OFF:
            events.sendCommand("Sufragerie_Daytime", "OFF")
            if items["Logging"] == ON:
                sufra2_daytime_switch.log.info("Daytime received command OFF")
@rule("Decizie cand Bucatarie1_Daytime e activ", description="Item Bucatarie1_Daytime received command ON", tags=["Illumination", "Bucatarie"])
@when("Item Bucatarie1_Daytime received update")
def bucatarie1_daytime_switch(event):
    if event.itemState == ON:
        if items["Bec_TechPro4"] != ON:
            events.sendCommand("Bucatarie_Daytime", "ON")
            if items["Logging"] == ON:
                bucatarie1_daytime_switch.log.info("Daytime received command ON")
    if event.itemState == OFF:
        if items["Philips_Daytime"] == OFF:
            events.sendCommand("Bucatarie_Daytime", "OFF")
            if items["Logging"] == ON:
                bucatarie1_daytime_switch.log.info("Daytime received command OFF")
@rule("Decizie cand Philips_Daytime e activ", description="Item Philips_Daytime received command ON", tags=["Illumination", "Bucatarie"])
