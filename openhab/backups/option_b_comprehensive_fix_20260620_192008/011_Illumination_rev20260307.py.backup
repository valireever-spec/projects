#Chiar si cand e lumina suficienta, la aprinderea becurilor, trebuie ca lumina sa ramana permanent aprinsa#
@rule("PermDormC forced switch on", description="PermDormC change to ON", tags=["forced", "Sonoffmini1"])
#@when("Item Sonoffmini1_Power changed")
@when("Item Sonoffmini1_Alive changed")
def forced_dormc(event):
    if event.itemState == ON:
        # FIX-sleep: replaced time.sleep(1) with createTimer
        def _forced_dormc_on():
            if items["DormC_Daytime"] != OFF:
                if items["DormitorC_Illuminance_Switch"] != ON:
                    #if items["Sonoffmini1_Alive"] != OFF:
                    events.sendCommand("PermDormC", "ON")
                    events.sendCommand("PermDormC_Forced", "ON")
                    forced_dormc.log.info("Sonoffmini1 a activat fortat PermDormC si PermDormC_Forced")
        ScriptExecution.createTimer(DateTime.now().plusSeconds(1), _forced_dormc_on)
    if event.itemState == OFF:
        forced_dormc.log.info("Sonoffmini1_Reachable este inactiv")
        if items["PermDormC_Forced"] != OFF:
            # FIX-sleep: replaced sleep(0.5)+cmd+sleep(0.5)+cmd with chained timers
            def _forced_dormc_off_step2():
                events.sendCommand("PermDormC", "OFF")
                forced_dormc.log.info("Sonoffmini1 a dezactivat fortat PermDormC si PermDormC_Forced")
            events.sendCommand("PermDormC_Forced", "OFF")
            ScriptExecution.createTimer(DateTime.now().plusMillis(500), _forced_dormc_off_step2)
