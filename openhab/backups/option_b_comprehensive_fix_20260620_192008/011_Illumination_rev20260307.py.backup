def bucatarie2_daytime_switch(event):
    if event.itemCommand == ON:
        if items["Bec_TechPro4"] != ON:
            events.sendCommand("Bucatarie_Daytime", "ON")
            if items["Logging"] == ON:
                bucatarie2_daytime_switch.log.info("Daytime received command ON")
    if event.itemCommand == OFF:
        if items["Bucatarie1_Daytime"] == OFF:
            events.sendCommand("Bucatarie_Daytime", "OFF")
            if items["Logging"] == ON:
                bucatarie2_daytime_switch.log.info("Daytime received command OFF")
