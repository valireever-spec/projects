@rule("Decizie cand DormP1_Daytime e activ", description="Item DormP1_Daytime received command ON", tags=["Illumination", "DormitorP"])
@when("Item DormP1_Daytime received update")
def dormp1_daytime_switch(event):
    if event.itemState == ON:
        # FIX-sleep: replaced time.sleep(1) with createTimer
        def _dormp1_daytime_on():
            if items["Sonoffmini2_Alive"] == ON:
                if items["Sonoffmini2_Power"] != ON:
                    events.sendCommand("DormP_Daytime", "ON")
            #if ir.getItem("Sonoffmini2_Power").state != ON:
            if items["Sonoffmini2_Alive"] != ON:
                events.sendCommand("DormP_Daytime", "ON")
                if items["Logging"] == ON:
                    dormp1_daytime_switch.log.info("Daytime received command ON")
        ScriptExecution.createTimer(DateTime.now().plusSeconds(1), _dormp1_daytime_on)
    if event.itemState == OFF:
        if items["DormP2_Daytime"] == OFF:
            events.sendCommand("DormP_Daytime", "OFF")
            if items["Logging"] == ON:
                dormp1_daytime_switch.log.info("Daytime received command OFF")
@rule("Decizie cand DormP2_Daytime e activ", description="Item DormP2_Daytime received command ON", tags=["Illumination", "DormitorP"])
@when("Item DormP2_Daytime received update")
def dormp2_daytime_switch(event):
    if event.itemState == ON:
        # FIX-sleep: replaced time.sleep(1) with createTimer
        def _dormp2_daytime_on():
            if items["Sonoffmini2_Alive"] == ON:
                if items["Sonoffmini2_Power"] != ON:
                    events.sendCommand("DormP_Daytime", "ON")
            #if ir.getItem("Sonoffmini2_Power").state != ON:
            if items["Sonoffmini2_Alive"] != ON:
                events.sendCommand("DormP_Daytime", "ON")
                if items["Logging"] == ON:
                    dormp2_daytime_switch.log.info("Daytime received command ON")
        ScriptExecution.createTimer(DateTime.now().plusSeconds(1), _dormp2_daytime_on)
    if event.itemState == OFF:
        if items["DormP1_Daytime"] == OFF:
            events.sendCommand("DormP_Daytime", "OFF")
            if items["Logging"] == ON:
                dormp2_daytime_switch.log.info("Daytime received command OFF")
