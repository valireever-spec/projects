##011_Illumination_rev20240210.py
# 25.10.2021 Correction of the rules
# 09.03.2021 S-au corectat greselile din script
# 07.03.2021 S-a adaugat activarea Daytime doar cand becurile sunt stinse
# 22.02.2021
# Corrected the rules
#
# FIXES applied 2026-03-07:
#   OPT-irgetitem: replaced all 89 ir.getItem() calls with items[] dict lookups (state reads)
#     and string-based sendCommand/postUpdate (commands). ir.getItem() calls registry
#     on every invocation; items[] is a pre-populated dict — much lower overhead on
#     high-frequency illuminance/presence events.
#   FIX-sleep: Replaced all time.sleep()/sleep() calls with ScriptExecution.createTimer().
#              sleep() blocks the entire Jython rule engine thread.
#              11 sleep calls across 9 rules were replaced:
#              - sufra1/2_daytime_switch, dormp1/2_daytime_switch, dormc1/2_daytime_switch:
#                sleep(1) before reading Sonoffmini state -> deferred via 1s createTimer
#              - forced_dormc/p/sufra ON branch: sleep(1) -> 1s createTimer
#              - forced_dormc/p/sufra OFF branch: sleep(0.5)+cmd+sleep(0.5)+cmd -> cmd+500ms timer+cmd
#              - sufra_illum_level: sleep(0.5) x2 between pure arithmetic -> removed entirely
# 2026-05-02: UnDefType from org.eclipse.smarthome.core.types (ESH; OH 2.5.12).
from core.rules import rule
from core.triggers import when
from core.actions import ScriptExecution
from org.joda.time import DateTime
import core
from core.jsr223.scope import events, items
from org.eclipse.smarthome.core.types import UnDefType
from org.eclipse.smarthome.model.script.actions.Exec import executeCommandLine
from core.actions import LogAction
NULL = UnDefType.NULL
UNDEF = UnDefType.UNDEF
MinLightLevel = 0.008000000000000000
MinLightlux = 3.0
MinLightPhilips = 180
Xiaomilux = 18.0
levelLightSufra = None #20.08.2024
####nou###
@rule("Sufra1_deconz_Dark", description="Item Sufra1_Light_Illuminance changed", tags=["Illumination", "Sufra"])
@when("Item Sufra1_Light_Illuminance changed")
def sufra1_deconz_illum(event):
    if items["Sufra1_Light_Illuminance"] >= QuantityType(u"18.0 lx") and items["Sufragerie1_Daytime"] != ON:
        events.sendCommand("Sufragerie1_Daytime", "ON")
    elif items["Sufra1_Light_Illuminance"] < QuantityType(u"18.0 lx") and items["Sufragerie1_Daytime"] != OFF:
        events.sendCommand("Sufragerie1_Daytime", "OFF")
@rule("Sufra2_deconz_Dark", description="Item Sufra2_Light_Illuminance changed", tags=["Illumination", "Sufra"])
@when("Item Sufra2_Light_Illuminance changed")
def sufra2_deconz_illum(event):
    if items["Sufra2_Light_Illuminance"] >= QuantityType(u"18.0 lx") and items["Sufragerie2_Daytime"] != ON:
        events.sendCommand("Sufragerie2_Daytime", "ON")
    elif items["Sufra2_Light_Illuminance"] < QuantityType(u"18.0 lx") and items["Sufragerie2_Daytime"] != OFF:
        events.sendCommand("Sufragerie2_Daytime", "OFF")
