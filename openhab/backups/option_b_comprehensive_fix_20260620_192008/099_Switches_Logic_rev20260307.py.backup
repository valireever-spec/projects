ON = OnOffType.ON
OFF = OnOffType.OFF
NULL = UnDefType.NULL
#UNDEF = UnDefType.UNDEF
createTimer = ScriptExecution.createTimer

FireplaceTimerOff = None
Fireplace_startTimer = None
Fireplace_restartTimer = None
Priza1ForceOnTimer = None
Priza2ForceOnTimer = None
Priza3ForceOnTimer = None
FireplaceTimerOn = None
FireplaceTimerOff = None
KeepOnTime = 20

MinCLevel = u"0.055 A"
Current_Low = u"0.0 A"

MinCLevel_P1 = u"0.150 A"

@rule("Sonoffmini1 a activat Sonoffmini1_Alive", description="Sonoffmini1_Reachable este activ", tags=["forced", "Sonoffmini1"])
@when("Item Sonoffmini1_Reachable changed to ON")
@when("Item Sonoff1_Online changed to ON")
@when("Item ScriptParrot_Sonoff1_up changed to ON")
def sonoffmini1_alive_on(event):
	LogAction.logInfo("{}", "{} este activ", event.itemName)
	events.sendCommand("Sonoffmini1_Alive", "ON")
	LogAction.logInfo("{}", "{} a activat Sonoffmini1_Alive", event.itemName)

@rule("Sonoffmini1 a dezactivat Sonoffmini1_Alive", description="Sonoffmini1_Reachable este inactiv", tags=["forced", "Sonoffmini1"])
@when("Item Sonoffmini1_Reachable changed to OFF")
@when("Item Sonoff1_Online changed to OFF")
@when("Item ScriptParrot_Sonoff1_up changed to OFF")
def sonoffmini1_alive_off(event):
	LogAction.logInfo("{}", "{} este inactiv", event.itemName)
	events.sendCommand("Sonoffmini1_Alive", "OFF")
	LogAction.logInfo("{}", "{} a dezactivat Sonoffmini1_Alive", event.itemName)

