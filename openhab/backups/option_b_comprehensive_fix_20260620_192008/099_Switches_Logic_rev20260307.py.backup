			#Priza3ForceOnTimer.reschedule(DateTime.now().plusMinutes(KeepOnTime))

@rule("Rule TelefunkenTV Online transform", description="onoffto1or0", tags=["onff", "state"])
@when("Item ScriptParrot_Smarttv_telefunken_up changed")
def telefunkenswitch(event):
	if items["ScriptParrot_Smarttv_telefunken_up"] == ON:
		events.sendCommand("ScriptParrot_Telefunkentv_state", "1")
	if items["ScriptParrot_Smarttv_telefunken_up"] == OFF:
		events.sendCommand("ScriptParrot_Telefunkentv_state", "0")

