	#if items["Priza2ForceOn"] != OFF:
	events.sendCommand("Priza2ForceOn", "OFF")
	events.sendCommand("Priza2RdytoForce", "OFF")
	Priza2ForceOnTimer.cancel()

@rule("Rule Priza2 forced to stay on for a period", description="on", tags=["on", "state"])
@when("Item Priza2_Current changed")
def priza2forceon(event):
	global Priza2ForceOnTimer
	if items["Priza2RdytoForce"] == ON and items["Priza2ForceOn"] != ON:
		events.sendCommand("Priza2ForceOn", "ON")
		if Priza2ForceOnTimer is None or Priza2ForceOnTimer.hasTerminated():
			Priza2ForceOnTimer = ScriptExecution.createTimer(DateTime.now().plusMinutes(KeepOnTime), timer_priza2forceon)
		#elif Priza2ForceOnTimer is not None and not Priza2ForceOnTimer.hasTerminated():
			#Priza2ForceOnTimer.reschedule(DateTime.now().plusMinutes(KeepOnTime))

@rule("Priza3_Current", description="Priza3_Current changes Priza3RdytoForce", tags=["Current", "Priza3"])
@when("Item Priza3_Current changed")
def priza3preforce1(event):
	lstValcurrPriza3 = event.oldItemState.floatValue()
	aktValcurrPriza3 = event.itemState.floatValue()

	if items["Priza3_Power"] == ON and items["Priza3_Current"] == QuantityType((Current_Low)):  ###Telefonul s-a scos de la incarcat
		if items["Priza3RdytoForce"] != ON:
			events.sendCommand("Priza3RdytoForce", "ON")
	if items["Priza3_Power"] == ON and lstValcurrPriza3 == QuantityType((Current_Low)):   ###Telefonul s-a bagat la incarcat
		if items["Priza3RdytoForce"] != ON:
			events.sendCommand("Priza3RdytoForce", "ON")
		if items["Priza3RdytoForce"] == ON and items["Priza3ForceOn"] == ON:
			if Priza3ForceOnTimer is None or Priza3ForceOnTimer.hasTerminated():
				Priza3ForceOnTimer = ScriptExecution.createTimer(DateTime.now().plusMinutes(KeepOnTime), timer_priza3forceon)
	if items["Priza3_Power"] == OFF and items["Priza3_Current"] == QuantityType((Current_Low)):
		if items["Priza3RdytoForce"] != OFF:
			events.sendCommand("Priza3RdytoForce", "OFF")
###Added on 02.06.2023###Rule when Priza3ForceOn and the phone is pulled from charger
	if items["Priza3_Current"] == QuantityType((Current_Low)) and lstValcurrPriza3 >= QuantityType((Current_Low)):
		if items["Priza3ForceOn"] == ON:
			events.sendCommand("Priza3ForceOn", "OFF")
			Priza3ForceOnTimer.cancel()
###Added on 02.06.2023###Rule when Priza3ForceOn and the phone is pulled from charger

@rule("Priza3_Power", description="Priza3_Power changes Priza3RdytoForce", tags=["Power", "Priza3"])
@when("Item Priza3_Power changed")
def priza3preforce2(event):
	if items["Priza3_Power"] == OFF and items["Priza3_Current"] > QuantityType((Current_Low)):
		if items["Priza3RdytoForce"] != OFF:
			events.sendCommand("Priza3RdytoForce", "OFF")
	#if items["Priza3_Power"] == ON and items["Priza3_Current"] == QuantityType((Current_Low)):
		#if items["Priza3RdytoForce"] != OFF:
			#events.sendCommand("Priza3RdytoForce", "OFF")

def timer_priza3forceon():
	#if items["Priza3ForceOn"] != OFF:
	events.sendCommand("Priza3ForceOn", "OFF")
	events.sendCommand("Priza3RdytoForce", "OFF")
	Priza3ForceOnTimer.cancel()

@rule("Rule Priza3 forced to stay on for a period", description="on", tags=["on", "state"])
@when("Item Priza3_Current changed")
def priza3forceon(event):
	global Priza3ForceOnTimer
	if items["Priza3RdytoForce"] == ON and items["Priza3ForceOn"] != ON:
		events.sendCommand("Priza3ForceOn", "ON")
		if Priza3ForceOnTimer is None or Priza3ForceOnTimer.hasTerminated():
