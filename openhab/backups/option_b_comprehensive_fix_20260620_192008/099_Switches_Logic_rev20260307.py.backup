@rule("Rule HMS2mqtt", description="HMS2mqtt", tags=["onoff", "state"])
@when("Item HMS2mqtt changed")
def hms2mqtt(event):
	if event.itemState == OFF:
		stophms2mqtt = executeCommandLine("/etc/openhab2/scripts/docker_hms2mqtt.sh stop", 10000)
		#events.postUpdate("HMS2mqtt", "OFF")
	elif event.itemState == ON:
		starthms2mqtt = executeCommandLine("/etc/openhab2/scripts/docker_hms2mqtt.sh start", 10000)
		#events.postUpdate("HMS2mqtt", "ON")

