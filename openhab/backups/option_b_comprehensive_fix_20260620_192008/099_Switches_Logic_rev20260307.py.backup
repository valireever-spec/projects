@rule("Telefunken online state", description="Telefunken", tags=["Telefunken", "online"])
@when("Item ScriptParrot_Telefunkentv_online changed")
def telefunkentv_online(event):
	if event.itemState == ON:
		events.postUpdate("SmartTVTelefunken_Online", "ON")
		events.postUpdate("Telefunken_Sw", "ON")
		events.postUpdate("Telefunken_state_num", "1")
	if event.itemState == OFF:
		events.postUpdate("SmartTVTelefunken_Online", "OFF")
		events.postUpdate("Telefunken_Sw", "OFF")
		events.postUpdate("Telefunken_state_num", "0")


@rule("Openhab2_service state", description="Openhab2_service", tags=["Openhab2_service", "state"])
@when("Item ScriptParrot_Openhab2_uptime changed")
def openhab2_uptime(event):
	if event.itemState == ON:
		events.postUpdate("Openhab2_uptime_num", "1")
	if event.itemState == OFF:
		events.postUpdate("Openhab2_uptime_num", "0")

### Reguli switch curent Prize
@rule("Rule when Priza1_current greater than defined level", description="Priza1_current_state", tags=["Current", "state"])
@when("Item Priza1_Current changed")
def Priza1current(event):
	state = items["Priza1_Current"]
	if isinstance(state, UnDefType):
		LogAction.logInfo("Priza1current", "Priza1_Current is UNDEF or NULL - skipping check.")
		return

	if state >= QuantityType(MinCLevel_P1):
		events.sendCommand("Priza1_Consum", "ON")
	else:
		events.sendCommand("Priza1_Consum", "OFF")

