@rule("House shutdown", description="House received update OFF", tags=["House", "Shutdown"])
@when("Item HouseShutdown received update OFF")
def house_off(event):
	house_off = executeCommandLine("/etc/openhab2/scripts/house_shutdown.sh", 10000)
	if items["Logging"] == ON:
		house_off.log.info("House switch off")

@rule("Rule when Pi_Fireplace is on", description="mqtt_state", tags=["mqtt", "state"])
@when("Item ScriptParrot_Pi_fireplace changed")
def fireplacemqtt(event):
	if str(event.itemState) == ON:
		#fireplacemqtt = executeCommandLine("/etc/openhab2/scripts/fireplace.sh", 10000)
		events.sendCommand("Pi_fireplace", "ON")
		events.postUpdate("Fireplace", "ON")
		events.postUpdate("Fireplace_restart", "OFF")

@rule("Rule Pi_fireplace", description="Pi_fireplace_state", tags=["onoff", "state"])
@when("Item Pi_fireplace changed")
def pifireplace(event):
	#global shutdownpifireplace
	#global startpifireplace
	if str(event.itemState) == OFF:
		shutdownpifireplace = executeCommandLine("/etc/openhab2/scripts/shutdownfireplace.sh", 10000)
		events.postUpdate("Pi_fireplace_restart", "OFF")
		events.postUpdate("Fireplace", "OFF")
	if str(event.itemState) == ON:
		startpifireplace = executeCommandLine("/etc/openhab2/scripts/fireplace.sh", 10000)

@rule("Rule Pi_fireplace_restart", description="Pi_fireplace_restart", tags=["restart", "state"])
@when("Item Pi_fireplace_restart changed")
def pifireplacerestart(event):
	#global restartpifireplace
	if str(event.itemState) == ON:
		restartpifireplace = executeCommandLine("/etc/openhab2/scripts/restartfireplace.sh", 10000)

def timer1_fireplace():
	global FireplaceTimerOn
	if items["Pi_fireplace"] == OFF:
		events.sendCommand("Pi_fireplace", "ON")
	FireplaceTimerOn.cancel()

def timer2_fireplace():
	global FireplaceTimerOff
	events.sendCommand("Priza8_Power", "OFF")
	FireplaceTimerOff.cancel()

@rule("Rule when Fireplace changes", description="onoff", tags=["onoff", "state"])
@when("Item Fireplace changed")
def fireplace(event):
	global FireplaceTimerOff
	global FireplaceTimerOn
	
	if event.itemState == ON:
		events.sendCommand("Priza8_Power", "ON")
		FireplaceTimerOn = ScriptExecution.createTimer(DateTime.now().plusMinutes(2), timer1_fireplace)

	elif event.itemState == OFF:
		events.sendCommand("Pi_fireplace", "OFF")
		if FireplaceTimerOff is None or FireplaceTimerOff.hasTerminated():
			FireplaceTimerOff = ScriptExecution.createTimer(DateTime.now().plusMinutes(2), timer2_fireplace)

def timer4_fireplace():
	events.sendCommand("Priza8_Power", "ON")
	events.postUpdate("Fireplace_restart", "OFF")
	Fireplace_startTimer.cancel()
	
def timer3_fireplace():
	global Fireplace_startTimer
	events.sendCommand("Priza8_Power", "OFF")
	Fireplace_restartTimer.cancel()
	if Fireplace_startTimer is None or Fireplace_startTimer.hasTerminated():
		Fireplace_startTimer = ScriptExecution.createTimer(DateTime.now().plusSeconds(10), timer4_fireplace)

@rule("Rule when Fireplace_restart changes", description="onoff", tags=["onoff", "state"])
@when("Item Fireplace_restart changed")
def fireplace_restart(event):
	global Fireplace_restartTimer
	if event.itemState == ON:
		events.sendCommand("Pi_fireplace", "OFF")
		if Fireplace_restartTimer is None or Fireplace_restartTimer.hasTerminated():
			Fireplace_restartTimer = ScriptExecution.createTimer(DateTime.now().plusMinutes(1), timer3_fireplace)

@rule("Priza1_Current rose from zero", description="Priza1_Current changed from 0.0 - logger", tags=["Current", "Priza1"])
@when("Item Priza1_Current changed from 0.0")
def priza1test0(event):
	priza1test0.log.info("Priza1 current a crescut de la 0")

def safe_float(state):
	if state in [UnDefType.NULL, UnDefType.UNDEF, None]:
		return 0.0
	try:
		if isinstance(state, QuantityType):
			return float(state.floatValue())
		else:
			return float(str(state))
	except:
		return 0.0

@rule("Priza1_Current", description="Priza1_Current changes Priza1RdytoForce", tags=["Current", "Priza1"])
@when("Item Priza1_Current changed")
def priza1preforce1(event):
	#lstValcurrPriza1 = event.oldItemState.floatValue()
	#aktValcurrPriza1 = event.itemState.floatValue()
	lstValcurrPriza1 = safe_float(event.oldItemState)
	aktValcurrPriza1 = safe_float(event.itemState)

	if items["Priza1_Power"] == ON and items["Priza1_Current"] == QuantityType((Current_Low)):  ###Telefonul s-a scos de la incarcat
		if items["Priza1RdytoForce"] != ON:
			events.sendCommand("Priza1RdytoForce", "ON")
	if items["Priza1_Power"] == ON and lstValcurrPriza1 == QuantityType((Current_Low)):   ###Telefonul s-a bagat la incarcat
		if items["Priza1RdytoForce"] != ON:
			events.sendCommand("Priza1RdytoForce", "ON")
		if items["Priza1RdytoForce"] == ON and items["Priza1ForceOn"] == ON:
			if Priza1ForceOnTimer is None or Priza1ForceOnTimer.hasTerminated():
				Priza1ForceOnTimer = ScriptExecution.createTimer(DateTime.now().plusMinutes(KeepOnTime), timer_priza1forceon)
	if items["Priza1_Power"] == OFF and items["Priza1_Current"] == QuantityType((Current_Low)):
		if items["Priza1RdytoForce"] != OFF:
			events.sendCommand("Priza1RdytoForce", "OFF")
###Added on 02.06.2023###Rule when Priza1ForceOn and the phone is pulled from charger
	if items["Priza1_Current"] == QuantityType((Current_Low)) and lstValcurrPriza1 >= QuantityType((Current_Low)):
		if items["Priza1ForceOn"] == ON:
			events.sendCommand("Priza1ForceOn", "OFF")
			Priza1ForceOnTimer.cancel()
###Added on 02.06.2023###Rule when Priza1ForceOn and the phone is pulled from charger

@rule("Priza1_Power", description="Priza1_Power changes Priza1RdytoForce", tags=["Power", "Priza1"])
@when("Item Priza1_Power changed")
def priza1preforce2(event):
	if items["Priza1_Power"] == OFF and items["Priza1_Current"] > QuantityType((Current_Low)): ###Telefonul a ajuns nivelul de incarcare
		if items["Priza1RdytoForce"] != OFF:
			events.sendCommand("Priza1RdytoForce", "OFF")
	#if items["Priza1_Power"] == ON and items["Priza1_Current"] == QuantityType((Current_Low)):
		#if items["Priza1RdytoForce"] != OFF:
			#events.sendCommand("Priza1RdytoForce", "OFF")

def timer_priza1forceon():
	#if items["Priza1ForceOn"] != OFF:
	events.sendCommand("Priza1ForceOn", "OFF")
	events.sendCommand("Priza1RdytoForce", "OFF")
	Priza1ForceOnTimer.cancel()

@rule("Rule Priza1 forced to stay on for a period", description="on", tags=["on", "state"])
@when("Item Priza1_Current changed")
def priza1forceon(event):
	global Priza1ForceOnTimer
	# FIX4: skip ForceOn if battery is already full — prevents a rapid ON/OFF
	# power cycle (ForceOn turns socket ON, current=0 triggers full-charge
	# detection in 017, which immediately turns the socket OFF again).
	if items["Priza1_BatteryFull"] == ON:
		LogAction.logInfo("Priza1ForceOn", "Skipped — Priza1_BatteryFull is ON")
		return
	if items["Priza1RdytoForce"] == ON and items["Priza1ForceOn"] != ON:
		events.sendCommand("Priza1ForceOn", "ON")
		if Priza1ForceOnTimer is None or Priza1ForceOnTimer.hasTerminated():
			Priza1ForceOnTimer = ScriptExecution.createTimer(DateTime.now().plusMinutes(KeepOnTime), timer_priza1forceon)
		#elif Priza1ForceOnTimer is not None and not Priza1ForceOnTimer.hasTerminated():
			#Priza1ForceOnTimer.reschedule(DateTime.now().plusMinutes(KeepOnTime))

@rule("Priza2_Current", description="Priza2_Current changes Priza2RdytoForce", tags=["Current", "Priza2"])
@when("Item Priza2_Current changed")
def priza2preforce1(event):
	lstValcurrPriza2 = event.oldItemState.floatValue()
	aktValcurrPriza2 = event.itemState.floatValue()

	if items["Priza2_Power"] == ON and items["Priza2_Current"] == QuantityType((Current_Low)):  ###Telefonul s-a scos de la incarcat
		if items["Priza2RdytoForce"] != ON:
			events.sendCommand("Priza2RdytoForce", "ON")
	if items["Priza2_Power"] == ON and lstValcurrPriza2 == QuantityType((Current_Low)):   ###Telefonul s-a bagat la incarcat
		if items["Priza2RdytoForce"] != ON:
			events.sendCommand("Priza2RdytoForce", "ON")
		if items["Priza2RdytoForce"] == ON and items["Priza2ForceOn"] == ON:
			if Priza2ForceOnTimer is None or Priza2ForceOnTimer.hasTerminated():
				Priza2ForceOnTimer = ScriptExecution.createTimer(DateTime.now().plusMinutes(KeepOnTime), timer_priza2forceon)
	if items["Priza2_Power"] == OFF and items["Priza2_Current"] == QuantityType((Current_Low)):
		if items["Priza2RdytoForce"] != OFF:
			events.sendCommand("Priza2RdytoForce", "OFF")
###Added on 02.06.2023###Rule when Priza2ForceOn and the phone is pulled from charger
	if items["Priza2_Current"] == QuantityType((Current_Low)) and lstValcurrPriza2 >= QuantityType((Current_Low)):
		if items["Priza2ForceOn"] == ON:
			events.sendCommand("Priza2ForceOn", "OFF")
			Priza2ForceOnTimer.cancel()
###Added on 02.06.2023###Rule when Priza2ForceOn and the phone is pulled from charger

