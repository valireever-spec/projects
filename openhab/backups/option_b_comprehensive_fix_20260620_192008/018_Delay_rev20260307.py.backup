@rule("DelayTimerTelefunken received update", description="DTTelefunken received update", tags=["Timer", "Telefunken"])
@when("Item DTTelefunken received update")
def telefunken_timer(event):
	# No sleeps in original — unchanged
	events.postUpdate(ir.getItem("DelayTimerTelefunken"), ir.getItem("DTTelefunken").state)
	if items["Logging"] == ON:
		telefunken_timer.log.info("Light timer Telefunken received update")
