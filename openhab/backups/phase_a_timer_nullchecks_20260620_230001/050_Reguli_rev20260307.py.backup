# FIX  2026-03-07: removed 'from core.utils import sendCommandCheckFirst, postUpdateCheckFirst'
# OPT  2026-03-07: replaced 82 sendCommand(ir.getItem("X"), val) with sendCommand("X", str(val))
#     and 7 ir.getItem("X").state reads with items["X"] dict lookups.
#     Module-level d_*/dt_* item-object caches (L88-L103) intentionally kept as
#     ir.getItem() — they are used for .state.intValue() Java method calls which
#     require the raw Item object, not the state wrapper.
#   Cross-file imports don't work in OH2 Jython. postUpdateCheckFirst() call in
#   telefunken_stop replaced by comment (sendCommand below already sends the IR command).
# FIX 2026-03-07: renamed duplicate @rule names (would cause silent rule overwrite in OH2):
#   'Sufra_Presence received ON' x2 -> unique names per trigger type
#   'DormP_Presence received ON' x2 -> unique names per trigger type
#   'Item \'...' x4 cancel-timer rules -> OH2 truncates name at single-quote; renamed without quotes
# FIX 2026-03-07: removed time.sleep(0.5) x2 in dormp_presence DarkDormP branch

NULL = UnDefType.NULL
ON = OnOffType.ON
OFF = OnOffType.OFF

def is_state(item_state, target_state):
    """Safe state comparison using string conversion. Handles Java State objects reliably."""
    return str(item_state).strip() == str(target_state).strip()

UNDEF = UnDefType.UNDEF

###

