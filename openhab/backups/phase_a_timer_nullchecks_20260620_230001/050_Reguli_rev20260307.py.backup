@rule("Sufra_Presence received command - holddown", description="Sufra_Presence received command ON", tags=["Presence", "Sufragerie"])
@when("Item Sufra_Presence received command")
def sufragerie_presence_delay(event):
	global HDtimer3
	global HoldDown3
	global incr3
	global timeFract3
	global HoldDown3_3
	global DT_HDSufra
	global DT_HDLampa
	if is_state(items["Logging"], ON):
		sufragerie_presence_delay.log.info("There is presence in Sufragerie")
	if is_state(event.itemCommand, ON):
		if HDtimer3 is None or HDtimer3.hasTerminated():
				HoldDown3 = baseHoldDown3
				incr3 = 0
				events.sendCommand("HD3", "ON")
				HDtimer3 = ScriptExecution.createTimer(DateTime.now().plusSeconds(HoldDown3), timer3_dynamic_delay)
				
		elif HDtimer3 is not None and not HDtimer3.hasTerminated():
			incr3 += 1
			timeFract3 = (baseHoldDown3 / incr3)
			HoldDown3_3 = HoldDown3
			if is_state(items["Sufragerie_Daytime"], OFF):
				HoldDown3 = int(str(HoldDown3_3)) + timeFract3
			if is_state(items["Sufragerie_Daytime"], ON):
				HoldDown3 = (int(str(items["DTSufragerie"])) * 60)
			events.sendCommand("HDSufragerie", str(HoldDown3))
			####
			if int(str(items["DTLampa"])) == 0:
				events.postUpdate("DTLampa", str(3))
			if d_lampa.state == 0 or d_lampa.state == NULL:
				events.sendCommand("DelayTimerLampa", str(int(str(items["DTLampa"])) * 60 + int(str(items["HDSufragerie"]))))

			if int(str(items["DTSufragerie"])) == 0:
				events.postUpdate("DTSufragerie", str(7))
			if d_sufra.state == 0 or d_sufra.state == NULL:
				events.sendCommand("DelayTimerSufragerie", str(int(str(items["DTSufragerie"])) * 60 + int(str(items["HDSufragerie"]))))
			###
			if (items["PermSufra"] == OFF or items["DarkSufra"] == OFF) and items["Sufragerie_Illuminance_Switch"] == ON:
				DT_HDSufra = int(str(items["DTSufragerie"])) * 60 + int(str(items["HDSufragerie"]))
				DT_HDLampa = int(str(items["DTLampa"])) * 60 + int(str(items["HDSufragerie"]))
				HDtimer3.reschedule(DateTime.now().plusSeconds(HoldDown3))
				events.sendCommand("DelayTimerLampa", str(DT_HDLampa))
				events.sendCommand("DelayTimerSufragerie", str(DT_HDSufra))
				events.sendCommand("HD3", "ON")
				if is_state(items["Logging"], ON):
					sufragerie_presence_delay.log.info("DelayTimerLampa", "SufraLampa: Timerul Lampa este setat la " + DelayTimerLampa.state)
					sufragerie_presence_delay.log.info("DelayTimerSufra", "Sufragerie: Timerul Sufra este setat la " + DelayTimerSufragerie.state)
			
