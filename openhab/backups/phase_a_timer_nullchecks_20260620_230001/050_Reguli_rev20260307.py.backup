def timer12_hol():
	events.sendCommand("Hol_PIR1", "OFF")
	occupancyTimer12.cancel()

@rule("SNZB1_Presence received ON", description="SNZB1_Presence received update ON", tags=["Occupancy", "Hol"])
@when("Item SNZB1_Presence received update")
def hol_occupancy(event):
	global occupancyTimer12
	global timeout1Seconds
	if is_state(event.itemState, ON):
		if occupancyTimer12 is None or occupancyTimer12.hasTerminated():
			events.sendCommand("Hol_PIR1", "ON")
			events.sendCommand("WOL_pfsense", "ON")
			events.postUpdate("PfSense_Online", "ON")
			occupancyTimer12 = ScriptExecution.createTimer(DateTime.now().plusSeconds(timeout1Seconds), timer12_hol)
		elif occupancyTimer12 is not None and not occupancyTimer12.hasTerminated():
			events.sendCommand("Hol_PIR1", "ON")

@rule("PfSense_Online received update", description="PfSense_Online received update", tags=["pfSense", "update"])
@when("Item PfSense_Online received update")
def pfsense_online(event):
	if is_state(event.itemState, OFF):
		#pfsense_off = Exec.executeCommandLine("/etc/openhab2/scripts/shutdownpfsense.sh", 10000)
		events.postUpdate("WOL_pfsense", "OFF")
	if is_state(event.itemState, ON):
		events.sendCommand("WOL_pfsense", "ON")

@rule("Regula cand HomePresence este inactiv", description="HomePresence is OFF", tags=["HomePresence", "Acasa"])
@when("Item HomePresence changed")
def homepresence(event):
	if is_state(event.itemState, OFF):
		events.sendCommand("Sufragerie_Daytime", "ON")
		events.sendCommand("DormP_Daytime", "ON")
		events.sendCommand("DormC_Daytime", "ON")
		events.sendCommand("Bucatarie_Daytime", "ON")
		hpTimersufra   = ScriptExecution.createTimer(DateTime.now().plusSeconds(1), lambda: events.sendCommand("Becuri_Sufragerie", "OFF"))
		hpTimerlampa   = ScriptExecution.createTimer(DateTime.now().plusSeconds(1), timer1_lampa_sufra)
		hpTimerparinti = ScriptExecution.createTimer(DateTime.now().plusSeconds(1), lambda: events.sendCommand("Sonoffmini2_Power", "OFF"))
		hpTimercopii   = ScriptExecution.createTimer(DateTime.now().plusSeconds(1), lambda: events.sendCommand("Sonoffmini1_Power", "OFF"))
		hpTimertelefunken = ScriptExecution.createTimer(DateTime.now().plusSeconds(1), timer1_telefunken)
	if is_state(event.itemState, ON):
		events.sendCommand("WOL_pfsense", "ON")

# ---------------------------------------------------------------------------
# KE100 DormAlex — presence-based thermostat control v2
#
# Items:
#   Dorm1_Presence          — Switch, consolidated DormP presence
#   KE100_TargetTemp        — Number, thermostat setpoint
#   KE100_CurrentTemp       — Number, measured temperature at valve
#   DormP1_pir_Temperature  — Number, PIR sensor 1 temperature
#   DormP2_pir_Temperature  — Number, PIR sensor 2 (closer to window)
#
# Setpoints:
#   KE100_TEMP_PRESENCE = 23 C  (defined, not sent — documents intent)
#   KE100_TEMP_ABSENCE  = 19 C  (day: after 15 min absence)
#   KE100_TEMP_NIGHT    = 22 C  (21:00-07:00 hard cron, always wins)
#
# Presence rule (Dorm1_Presence changed):
#   ON  -> cancel absence timer silently; no temperature change
#   OFF -> start/restart 15-min absence timer; on expiry set 19 C
#
# Night schedule (hard crons):
#   21:00 -> cancel absence timer (night takes ownership); set 22 C
#   07:00 -> do NOT set any temperature; wait for next presence event
#
# Open window detection (DormP1/2_pir_Temperature or KE100_CurrentTemp changed):
#   Suppressed when Dorm1_Presence is OFF
#   Condition: KE100_CurrentTemp - min(PIR1, PIR2) >= KE100_WINDOW_DELTA
#   On detection: log immediately; start 5-min cooldown (suppress repeat logs)
#   On cooldown expiry: if delta still open, log again and restart cooldown
#   No setpoint change — log only
#   When delta drops below threshold: log closed; reset open state and cooldown
#
# Battery preservation: ke100_set_temp() only commands if value differs from
#   current KE100_TargetTemp state. NULL/UNDEF: send unconditionally.
#
# Startup: no default temperature — act only on state changes.
# Schulfrei_Alex: ignored.
# ---------------------------------------------------------------------------

