@rule("Telefunken reachablility", description="SmartTVTelefunken_Online Status", tags=["Status", "TV"])
@when("Item SmartTVTelefunken_Online changed")
def telefunken_stat(event):
	if is_state(event.itemState, OFF):
		events.postUpdate("Telefunken_Sw", "OFF")
		if is_state(items["Logging"], ON):
			telefunken_stat.log.info("Telefunken","is not reachable")
	elif is_state(event.itemState, ON):
		events.postUpdate("Telefunken_Sw", "ON")
		if is_state(items["Logging"], ON):
			telefunken_stat.log.info("Telefunken","is reachable")

