def timer3_dynamic_delay():
	# Sufragerie holddown expiry — still uses individual globals (Lampa circuit).
	events.sendCommand("HD3", "OFF")
	HDtimer3.cancel()
	incr3 = 0

@rule("NAS wake up", description="NAS received update ON", tags=["NAS", "OMV"])
@when("Item NAS received update ON")
@when("Item NAS received command ON")
def nas_on(event):
	on_nas = executeCommandLine("/etc/openhab2/scripts/wakeomv.sh", 10000)
	if is_state(items["Logging"], ON):
		nas_on.log.info("NAS switch on")
	
@rule("NAS shutdown", description="NAS received update OFF", tags=["NAS", "OMV"])
@when("Item NAS received update OFF")
@when("Item NAS received command OFF")
def nas_off(event):
	off_nas = executeCommandLine("/etc/openhab2/scripts/shutdownomv.sh", 10000)
	if is_state(items["Logging"], ON):
		nas_off.log.info("NAS switch off")

@rule("pfSense wake up", description="pfSense_wake received update ON", tags=["firewall", "pfSense"])
@when("Item pfSense_wake received update ON")
def pfsense_on(event):
	on_pfsense = executeCommandLine("/etc/openhab2/scripts/wakepfSense.sh", 10000)
	if is_state(items["Logging"], ON):
		pfsense_on.log.info("pfSense wake up")
	
@rule("Update ACEStream List", description="Kodi_Acestream received update ON", tags=["ACEStream", "Kodi"])
@when("Item Kodi_Acestream received update ON")
def acestream_on(event):
	on_acestream = executeCommandLine("/etc/openhab2/scripts/get_ace_info.sh", 10000)
	if is_state(items["Logging"], ON):
		acestream_on.log.info("Kodi_Acestream received update")
		
		
@rule("Restart Openhab", description="Restart openhab local", tags=["Restart", "Openhab"])
@when("Item Restart_Openhab received update ON")
def openhab_off(event):
	#events.sendCommand("Backup_rrd4j", "ON")	### 26.05.2024 added 
	openhab_off = executeCommandLine("/etc/openhab2/scripts/halt-reboot.sh", 10000)
	if is_state(items["Logging"], ON):
		openhab_off.log.info("Openhab will be restarted")

@rule("Sufragerie switch on", description="Becuri_Sufragerie changed to ON", tags=["light", "TechPro"])
@when("Item Becuri_Sufragerie changed to ON")
def sufragerie_on(event):
	events.sendCommand("Sonoffmini3_Power", "ON")
	if is_state(items["Logging"], ON):
		sufragerie_on.log.info("Lights sufragerie switch on")

@rule("Sufragerie switch off", description="Becuri_Sufragerie changed to OFF", tags=["light", "TechPro"])
@when("Item Becuri_Sufragerie changed to OFF")
def sufragerie_off(event):
	events.sendCommand("Sonoffmini3_Power", "OFF")
	events.sendCommand("Bec_TechPro2", "OFF")
	events.sendCommand("Bec_TechPro3", "OFF")
	if _occ_sufra[0] is not None and not _occ_sufra[0].hasTerminated():
		_occ_sufra[0].cancel()
	if is_state(items["Logging"], ON):
		sufragerie_off.log.info("Lights sufragerie switch off")

@rule("Sufragerie dimmer update", description="Sufragerie dimmed", tags=["light", "TechPro"])
@when("Item Becuri_Sufragerie_Dimmer received update")
def sufragerie_dim(event):
	dim_tpro1 = executeCommandLine("/etc/openhab2/misc/lights/bec_techpro1.sh dim " + str(items["Bec_TechPro1_Dimmer"]), 10000)
	dim_tpro2 = executeCommandLine("/etc/openhab2/misc/lights/bec_techpro2.sh dim " + str(items["Bec_TechPro2_Dimmer"]), 10000)
	dim_tpro3 = executeCommandLine("/etc/openhab2/misc/lights/bec_techpro3.sh dim " + str(items["Bec_TechPro3_Dimmer"]), 10000)  # FIX: was Bec_TechPro2_Dimmer (copy-paste bug)
	if is_state(items["Logging"], ON):
		sufragerie_dim.log.info("sufragerie dimm " + str(items["Becuri_Sufragerie_Dimmer"]))

