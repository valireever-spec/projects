@rule("Sonoff2_Online changed", description="Sonoff2_Online changed to Off", tags=["Sonoff2_Online", "DormP"])
@when("Item Sonoff2_Online changed")
def sonoffmini2_power_ping(event):
	if is_state(event.itemState, OFF):
		events.postUpdate("Sonoffmini2_Power", "OFF")
		LogAction.logInfo("sonoffmini2_power_ping", "Sonoffmini2 didn't repond to ping. Sonoffmini2 is now [{}]", items["Sonoff2_Online"])
		if _occ_dormp[0] is not None and not _occ_dormp[0].hasTerminated():
			_occ_dormp[0].cancel()
		
