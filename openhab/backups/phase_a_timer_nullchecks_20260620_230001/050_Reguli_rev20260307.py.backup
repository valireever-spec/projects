def timer1_sufra():
	events.sendCommand("Sufra_Pir1", "OFF")
	occupancyTimer1.cancel()

@rule("SufragerieSenzorMiscare_Occupancy received ON", description="SufragerieSenzorMiscare_Occupancy received update ON", tags=["Occupancy", "Sufra"])
#@when("Item SufragerieSenzorMiscare_Occupancy received update")
@when("Item Sufra1_pir_Presence received update")
def sufra1_occupancy(event):
	global occupancyTimer1
	global timeout1Seconds
	if is_state(event.itemState, ON):
		if occupancyTimer1 is None or occupancyTimer1.hasTerminated():
			events.sendCommand("Sufra_Pir1", "ON")
			occupancyTimer1 = ScriptExecution.createTimer(DateTime.now().plusSeconds(timeout1Seconds), timer1_sufra)
		elif occupancyTimer1 is not None and not occupancyTimer1.hasTerminated():
			events.sendCommand("Sufra_Pir1", "ON")

