@rule("TechPro1 switch onoff", description="Bec_TechPro1", tags=["light", "TechPro"])
@when("Item Bec_TechPro1 received command")
def techpro1_onoff(event):
	if is_state(event.itemCommand, ON):
		on_tpro1 = executeCommandLine("/etc/openhab2/misc/lights/bec_techpro1.sh on", 10000)
	if is_state(event.itemCommand, OFF):
		off_tpro1 = executeCommandLine("/etc/openhab2/misc/lights/bec_techpro1.sh off", 10000)
	if is_state(items["Logging"], ON):
		techpro1_on.log.info("techpro1 was switched " + str(items["Bec_TechPro1"]))

