@rule("Cinema1 changed ON", description="Cinema1 changed ON", tags=["Cinema1", "Sufra"])
@when("Item Cinema1 changed")
def switch_cinema1(event):
	global occupancyTimer1
	if is_state(event.itemState, ON):
		#events.sendCommand (ir.getItem("Cinema1"), ON)
		#if is_state(items["Logging"], ON):
		if is_state(items["Cinema"], OFF): #Test 28.02.2023
			events.sendCommand (ir.getItem("Cinema"), ON) #Test 28.02.2023
		if occupancyTimer1 is None or occupancyTimer1.hasTerminated():
			occupancyTimer1 = ScriptExecution.createTimer(DateTime.now().plusMinutes(timeout1Minutes), timer1_cinema)
		switch_cinema1.log.info("Cinema, S-a activat")
	elif is_state(event.itemState, OFF):
		#events.sendCommand (ir.getItem("Cinema1"), OFF)
		#if is_state(items["Logging"], ON):
		switch_cinema1.log.info("Cinema1 was deactivated, No longer activity in the room")
			
@rule("Cinema2 changed ON", description="Cinema2 changed ON", tags=["Cinema2", "DormP"])
@when("Item Cinema2 changed")
def switch_cinema2(event):
	global occupancyTimer4
	if is_state(event.itemState, ON):
		if is_state(items["Cinema1"], OFF):
			if occupancyTimer4 is None or occupancyTimer4.hasTerminated():
				occupancyTimer4 = ScriptExecution.createTimer(DateTime.now().plusMinutes(timeout4Minutes), timer4_cinema)
				#if is_state(items["Logging"], ON):
				switch_cinema2.log.info("Cinema was deactivated, Seemingly nobody in Living Room")

