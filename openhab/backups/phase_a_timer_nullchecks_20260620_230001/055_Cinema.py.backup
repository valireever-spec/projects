@rule("Sufra_Presence_Cinema received ON", description="Sufra_Presence changed ON", tags=["Presence", "Sufragerie"])
@when("Item Sufra_Presence changed")
def sufragerie_cinema1(event):
	global occupancyTimer1
	if is_state(event.itemState, ON):
		#if is_state(items["Logging"], ON):
		sufragerie_cinema1.log.info("Cinema1, S-a activat")
		if occupancyTimer1 is None or occupancyTimer1.hasTerminated():
			events.sendCommand (ir.getItem("Cinema1"), ON)
			#if is_state(items["Logging"], ON):
			sufragerie_cinema1.log.info("Cinema1, Creating Timer")
			occupancyTimer1 = ScriptExecution.createTimer(DateTime.now().plusMinutes(timeout1Minutes), timer1_cinema)
			#if is_state(items["Logging"], ON):
			sufragerie_cinema1.log.info("Cinema1, Timer Expired")
		elif occupancyTimer1 is not None and not occupancyTimer1.hasTerminated():
			occupancyTimer1.reschedule(DateTime.now().plusMinutes(timeout1Minutes))
			events.sendCommand (ir.getItem("Cinema1"), ON)

