##016_HomePresence_rev20240725.py
# FIXES applied 2026-03-07:
#   FIX-sleep: Removed all time.sleep(0.5) calls.
#              Each sleep was placed immediately before a timer.reschedule() call
#              as an informal guard. reschedule() is safe to call without a preceding
#              sleep — the Joda timer API is thread-safe. Removing the sleeps returns
#              the rule engine thread immediately instead of blocking it for 500ms.
# 2026-05-02: UnDefType already org.eclipse.smarthome.core.types (ESH; OH 2.5.12 project convention).
###
from core.rules import rule
from core.triggers import when
from core.actions import ScriptExecution
from org.joda.time import DateTime
import core
from org.eclipse.smarthome.core.types import UnDefType
from core.actions import LogAction
from core.jsr223.scope import events, items
NULL = UnDefType.NULL
UNDEF = UnDefType.UNDEF
from oh_utils import ctrl_dev  # shared module at jsr223/python/oh_utils.py
OFF = OnOffType.OFF

def is_state(item_state, target_state):
    """Safe state comparison using string conversion. Handles Java State objects reliably."""
    return str(item_state).strip() == str(target_state).strip()

createTimer = ScriptExecution.createTimer
# Timer variables
DelayTimer1 = None
DelayTimer1_1 = None
timeoutMinutes = 45
HomePres = ir.getItem("HomePresence")
DelayTimer2 = None
DelayTimer2_1 = None
timeoutMinutes2 = 5
TelOnline = ir.getItem("TelephoneOnline")
DelayTimerGargoyleOn = None
DelayTimerDAP0On = None
DelayTimerDAP1On = None
DelayTimerDAP2On = None
DelayTimerGargoyleOff = None
DelayTimerDAP0Off = None
DelayTimerDAP1Off = None
DelayTimerDAP2Off = None
timeoutRouter = 5
DAP0_res = ir.getItem("Repeater0_restart")
DAP1_res = ir.getItem("Repeater1_restart")
DAP2_res = ir.getItem("Repeater2_restart")
Gargoyle_res = ir.getItem("Gargoyle_restart")
def timer1_homepresence_off():
    if TelOnline.state != ON and items["HomePresence"] != OFF:
        events.sendCommand("HomePresence", "OFF")
        if DelayTimer1 is not None and not DelayTimer1.hasTerminated():
            DelayTimer1.cancel()
        LogAction.logInfo("sufra_occupancy", "HomePresence is cancelled by Presence OFF")
def homepresence_on():
    if not is_state(items["HomePresence"], ON):
        events.sendCommand("HomePresence", "ON")
        LogAction.logInfo("Presence", "Somebody is at home now")
    if DelayTimer1_1 is not None and not DelayTimer1_1.hasTerminated():
        DelayTimer1_1.cancel()
    if DelayTimer1 is not None and not DelayTimer1.hasTerminated():
        # FIX-sleep: removed time.sleep(0.5) before reschedule — not needed, reschedule is thread-safe
        DelayTimer1.reschedule(DateTime.now().plusMinutes(timeoutMinutes))
@rule("Decizia 1 cand nu e nimeni acasa", description="Sufra_Presence received update OFF", tags=["Presence", "Sufra"])
@when("Item Sufra_Presence changed")
def sufra_occupancy(event):
    global DelayTimer1, DelayTimer1_1
    day_periods = ["DAY", "AFTERNOON", "EVENING"]
    if is_state(event.itemState, OFF):
        if items["vTimeOfDay"] in [StringType(period) for period in day_periods]:
            if all(items[presence] != ON for presence in ["Dorm1_Presence", "Dorm2_Presence", "Bucatarie2_Presence", "SNZB1_Presence"]):
                if DelayTimer1 is None or DelayTimer1.hasTerminated():
                    LogAction.logInfo("HomePresence", "DelayTimer1 is started by Sufra_Presence OFF")
                    DelayTimer1 = ScriptExecution.createTimer(DateTime.now().plusMinutes(timeoutMinutes), timer1_homepresence_off)
                    if is_state(items["Logging"], ON):
                        sufra_occupancy.log.info("Presence", "Nobody home")
                elif DelayTimer1 is not None and not DelayTimer1.hasTerminated():
                    # FIX-sleep: removed time.sleep(0.5) before reschedule
                    DelayTimer1.reschedule(DateTime.now().plusMinutes(timeoutMinutes))
    elif is_state(event.itemState, ON):
        DelayTimer1_1 = ScriptExecution.createTimer(DateTime.now().plusSeconds(1), homepresence_on)
        if is_state(items["Logging"], ON):
            sufra_occupancy.log.info("Presence Sufra", "Somebody is at home now")
