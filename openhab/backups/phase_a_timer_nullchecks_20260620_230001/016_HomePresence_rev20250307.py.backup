def timer1_tel_presence_off():
	if TelOnline.state == ON or TelOnline.state == NULL:
		events.sendCommand("TelephoneOnline", "OFF")
	DelayTimer2.cancel()
	LogAction.logInfo("TelephonePresence", "TelephoneOnline is cancelled by Presence OFF")
def tel_presence_on():
	if TelOnline.state == OFF or TelOnline.state == NULL:
		events.sendCommand("TelephoneOnline", "ON")
		LogAction.logInfo("TelephonePresence", "Somebody is at home now")
	if DelayTimer2_1 is not None and not DelayTimer2_1.hasTerminated():
		DelayTimer2_1.cancel()
	if DelayTimer2 is not None and not DelayTimer2.hasTerminated():
		DelayTimer2.reschedule(DateTime.now().plusMinutes(timeoutMinutes2))
@rule("Decizia 1 cand nu e niciun telefon acasa", description="Adina_s_a52_up received update", tags=["Telephone", "Adina"])
@when("Item ScriptParrot_Adina_s_a52_up changed")
def Adina_Tel_online(event):
	global DelayTimer2
	global DelayTimer2_1
	if is_state(event.itemState, OFF):
		if items["ScriptParrot_Redmi_note_up"] == OFF and items["ScriptParrot_Galaxy_s20_fe_5g_up"] == OFF:
			if DelayTimer2 is None or DelayTimer2.hasTerminated():
				DelayTimer2 = ScriptExecution.createTimer(DateTime.now().plusMinutes(timeoutMinutes2), timer1_tel_presence_off)
			elif DelayTimer2 is not None and not DelayTimer2.hasTerminated():
				DelayTimer2.reschedule(DateTime.now().plusMinutes(timeoutMinutes2))
	elif is_state(event.itemState, ON):
		DelayTimer2_1 = ScriptExecution.createTimer(DateTime.now().plusSeconds(1), tel_presence_on)
