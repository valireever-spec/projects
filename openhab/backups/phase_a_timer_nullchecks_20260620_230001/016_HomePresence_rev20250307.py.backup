def homepresenceon():
	global DelayTimerGargoyleOn
	global DelayTimerDAP0On
	global DelayTimerDAP1On
	global DelayTimerDAP2On
	global DelayTimerON
	if DelayTimerON is not None and not DelayTimerON.hasTerminated():
		DelayTimerON.cancel()
	events.postUpdate("Gargoyle_restart", "ON")
	if DelayTimerGargoyleOn is not None and not DelayTimerGargoyleOn.hasTerminated():
		DelayTimerGargoyleOn.cancel()
	events.postUpdate("Repeater0_restart", "ON")
	if DelayTimerDAP0On is not None and not DelayTimerDAP0On.hasTerminated():
		DelayTimerDAP0On.cancel()
	events.postUpdate("Repeater1_restart", "ON")
	if DelayTimerDAP1On is not None and not DelayTimerDAP1On.hasTerminated():
		DelayTimerDAP1On.cancel()
	events.postUpdate("Repeater2_restart", "ON")
	if DelayTimerDAP2On is not None and not DelayTimerDAP2On.hasTerminated():
		DelayTimerDAP2On.cancel()
@rule("HomePresence", description="HomePresence triggers other things", tags=["HomePresence", "Trigger"])
@when("Item HomePresence changed")
def homepresence_trigger(event):
	global DelayTimerGargoyleOn
	global DelayTimerGargoyleOff
	global DelayTimerDAP0On
	global DelayTimerDAP0Off
	global DelayTimerDAP1On
	global DelayTimerDAP1Off
	global DelayTimerDAP2On
	global DelayTimerON
	morning = "MORNING"
	day = "DAY"
	afternoon = "AFTERNOON"
	evening = "EVENING"
	night = "NIGHT"
	bed = "BED"
	if items["vTimeOfDay"] == StringType(afternoon) or items["vTimeOfDay"] == StringType(day): ##26.05.2024 added items["vTimeOfDay"] == StringType(day)
		if is_state(event.itemState, OFF):
			events.sendCommand("Repeater2_restart", "OFF")
			events.sendCommand("Repeater1_restart", "OFF")
			if DelayTimerDAP0Off is None or DelayTimerDAP0Off.hasTerminated():
				DelayTimerDAP0Off = ScriptExecution.createTimer(DateTime.now().plusMinutes(1), lambda: events.sendCommand("Repeater0_restart","OFF"))
			if DelayTimerGargoyleOff is None or DelayTimerGargoyleOff.hasTerminated():
				DelayTimerGargoyleOff = ScriptExecution.createTimer(DateTime.now().plusMinutes(2), lambda: events.sendCommand("Gargoyle_restart","OFF"))
			if DelayTimerDAP2On is None or DelayTimerDAP2On.hasTerminated():
				DelayTimerDAP2On = ScriptExecution.createTimer(DateTime.now().plusMinutes(timeoutRouter), lambda: events.sendCommand("Repeater2_restart","ON"))
			if DelayTimerDAP1On is None or DelayTimerDAP1On.hasTerminated():
				DelayTimerDAP1On = ScriptExecution.createTimer(DateTime.now().plusMinutes(timeoutRouter), lambda: events.sendCommand("Repeater1_restart","ON"))
			if DelayTimerDAP0On is None or DelayTimerDAP0On.hasTerminated():
				DelayTimerDAP0On = ScriptExecution.createTimer(DateTime.now().plusMinutes(6), lambda: events.sendCommand("Repeater0_restart","ON"))
			if DelayTimerGargoyleOn is None or DelayTimerGargoyleOn.hasTerminated():
				DelayTimerGargoyleOn = ScriptExecution.createTimer(DateTime.now().plusMinutes(7), lambda: events.sendCommand("Gargoyle_restart","ON"))
			#ctrl_dev("Priza11_Power", "OFF", items, events, command_type="sendCommand")
			LogAction.logInfo("Bucatarie", "Dezactivare Lumina Bucatarie")
			ctrl_dev("gBec_LampaSufra", "OFF", items, events, command_type="sendCommand")
			ctrl_dev("Led_Contr_Alex_Power", "OFF", items, events, command_type="sendCommand")
			ctrl_dev("Led_Contr_Adina_Power", "OFF", items, events, command_type="sendCommand")
			ctrl_dev("Pi_fireplace", "OFF", items, events, command_type="sendCommand")
		elif is_state(event.itemState, ON):
			DelayTimerON = ScriptExecution.createTimer(DateTime.now().plusSeconds(1), homepresenceon)
	elif is_state(items["vTimeOfDay"], StringType(day)):
		if is_state(items["Weekend"], OFF):
			if is_state(event.itemState, OFF):
				events.sendCommand("Repeater2_restart", "OFF")
				events.sendCommand("Repeater1_restart", "OFF")
				if DelayTimerDAP0Off is None or DelayTimerDAP0Off.hasTerminated():
					DelayTimerDAP0Off = ScriptExecution.createTimer(DateTime.now().plusMinutes(1), lambda: events.sendCommand("Repeater0_restart","OFF"))
				if DelayTimerGargoyleOff is None or DelayTimerGargoyleOff.hasTerminated():
					DelayTimerGargoyleOff = ScriptExecution.createTimer(DateTime.now().plusMinutes(2), lambda: events.sendCommand("Gargoyle_restart","OFF"))
				if DelayTimerDAP2On is None or DelayTimerDAP2On.hasTerminated():
					DelayTimerDAP2On = ScriptExecution.createTimer(DateTime.now().plusMinutes(timeoutRouter), lambda: events.sendCommand("Repeater2_restart","ON"))
				if DelayTimerDAP1On is None or DelayTimerDAP1On.hasTerminated():
					DelayTimerDAP1On = ScriptExecution.createTimer(DateTime.now().plusMinutes(timeoutRouter), lambda: events.sendCommand("Repeater1_restart","ON"))
				if DelayTimerDAP0On is None or DelayTimerDAP0On.hasTerminated():
					DelayTimerDAP0On = ScriptExecution.createTimer(DateTime.now().plusMinutes(6), lambda: events.sendCommand("Repeater0_restart","ON"))
				if DelayTimerGargoyleOn is None or DelayTimerGargoyleOn.hasTerminated():
					DelayTimerGargoyleOn = ScriptExecution.createTimer(DateTime.now().plusMinutes(7), lambda: events.sendCommand("Gargoyle_restart","ON"))
				#ctrl_dev("Priza11_Power", "OFF", items, events, command_type="sendCommand")
				LogAction.logInfo("Bucatarie", "Dezactivare Lumina Bucatarie")
				ctrl_dev("gBec_LampaSufra", "OFF", items, events, command_type="sendCommand")
				ctrl_dev("Led_Contr_Alex_Power", "OFF", items, events, command_type="sendCommand")
				ctrl_dev("Led_Contr_Adina_Power", "OFF", items, events, command_type="sendCommand")
				ctrl_dev("Pi_fireplace", "OFF", items, events, command_type="sendCommand")
			elif is_state(event.itemState, ON):
				DelayTimerON = ScriptExecution.createTimer(DateTime.now().plusSeconds(1), homepresenceon)
	elif items["vTimeOfDay"] == StringType(morning) or items["vTimeOfDay"] == StringType(evening) or items["vTimeOfDay"] == StringType(bed):
		if is_state(event.itemState, OFF):
			#ctrl_dev("Priza11_Power", "OFF", items, events, command_type="sendCommand")
			LogAction.logInfo("Bucatarie", "Dezactivare Lumina Bucatarie")
			ctrl_dev("gBec_LampaSufra", "OFF", items, events, command_type="sendCommand")
			ctrl_dev("Led_Contr_Alex_Power", "OFF", items, events, command_type="sendCommand")
			ctrl_dev("Led_Contr_Adina_Power", "OFF", items, events, command_type="sendCommand")
			ctrl_dev("Pi_fireplace", "OFF", items, events, command_type="sendCommand")
		elif is_state(event.itemState, ON):
			DelayTimerON = ScriptExecution.createTimer(DateTime.now().plusSeconds(1), homepresenceon)
